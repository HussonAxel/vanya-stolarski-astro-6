      {
        src: "/assets/services/premades/premade2.webp",
        alt: "Exemple de premade fantasy 2",
        label: "Premade 02",
      },
    ],
    tags: ["Fantasy", "Science-fiction", "Disponible"],
    description:
      "Des premades pour aller plus vite, tout en gardant une présence visuelle premium et un rendu cohérent avec ton projet.",
  },
  {
    name: "Jaspages",
    eyebrow: "Finition collector",
    price: "80 € / 120 €",
    accent: "#3d3834",
    format: "Édition collector",
    universe: "Fantasy & SF",
    focus: "Tranche personnalisée",
    gallery: [
      {
        src: "/assets/services/jaspages/jaspage-one.webp",
        alt: "Exemple de jaspage décoratif 1",
        label: "Ornement",
      },
      {
        src: "/assets/services/jaspages/jaspage-two.webp",
        alt: "Exemple de jaspage décoratif 2",
        label: "Motif",
