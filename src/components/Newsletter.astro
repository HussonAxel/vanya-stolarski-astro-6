<section
  id="newsletter"
  class="relative overflow-hidden bg-[#FFFAFA] py-20"
>
  <div class="container mx-auto grid max-w-5xl items-center gap-12 px-6 md:grid-cols-2">
    <div class="section-panel relative rounded-[2.5rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-8 shadow-[0_28px_90px_-55px_rgba(61,56,52,0.38)] backdrop-blur-sm md:p-10">
      <div class="space-y-6">
        <h2 class="font-serif text-4xl text-[#3d3834] text-balance">Ma Newsletter</h2>
        <p class="font-sans text-lg font-light text-[#3d3834]/78">
          Pour ne rien rater de mes prochaines sorties, concours ou ouverture de
          la boutique, n'hesite pas a t'abonner !
        </p>

        <div class="pt-4">
          <form class="flex flex-col gap-3">
            <input
              placeholder="Votre adresse email"
              class="border border-[#3d3834]/20 bg-transparent p-3 text-[#3d3834] outline-none transition-colors placeholder:text-[#3d3834]/30 focus:border-[#3a4d45]"
              type="email"
              required
            />
            <button
              type="submit"
              class="h-12 w-full bg-[#3a4d45] text-sm font-medium tracking-widest text-[#FFFAFA] uppercase transition-colors hover:bg-[#3a4d45]/90"
            >
              S'abonner
            </button>
            <p class="text-center text-[10px] text-[#3d3834]/78">
              By subscribing you agree to Substack's Terms of Use and Privacy
              Policy.
            </p>
          </form>
        </div>
      </div>
    </div>

    <div class="section-panel flex items-center justify-center rounded-[2.5rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-10 shadow-[0_28px_90px_-55px_rgba(61,56,52,0.38)] backdrop-blur-sm">
      <div class="space-y-4 text-center">
        <div
          class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-[#3a4d45] font-serif text-4xl text-[#FFFAFA] shadow-[0_22px_50px_-30px_rgba(58,77,69,0.7)]"
        >
          V
        </div>
        <h3 class="font-serif text-xl text-balance">Vanya Stolarski</h3>
        <p class="font-sans text-sm tracking-widest text-[#3d3834]/78 uppercase">
          Sur Substack
        </p>
      </div>
    </div>
  </div>
</section>
