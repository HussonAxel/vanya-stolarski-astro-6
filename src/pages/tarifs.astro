      {
        src: "/assets/services/jaspages/jaspage-four.webp",
        alt: "Exemple de jaspage décoratif 4",
        label: "Collection",
      },
    ],
    tags: ["Édition collector", "Fantasy", "Personnalisable"],
    description:
      "Le jaspage ajoute une vraie sensation d'objet précieux, avec une exécution conçue pour enrichir l'expérience du livre.",
  },
  {
    name: "Pages de garde",
    eyebrow: "Intérieur illustré",
    price: "Sous devis",
    accent: "#3d3834",
    format: "Double page",
    universe: "Univers sur mesure",
    focus: "Ouverture immersive",
    gallery: [
      {
        src: "/assets/services/pagedegarde/pdg1.webp",
        alt: "Exemple de pages de garde illustrées 1",
        label: "Ouverture",
      },
      {
        src: "/assets/services/pagedegarde/pdg2.webp",
