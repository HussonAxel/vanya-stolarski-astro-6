---
import { getUluleCampaignCard } from "../lib/ulule";

const campaign = await getUluleCampaignCard();
---

<div
    class="hero-card group relative h-full min-h-[22rem] overflow-hidden rounded-3xl bg-[#3a4d45] p-7 md:p-8 lg:rounded-[2rem] lg:p-9 xl:min-h-0"
>
    <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.12),transparent_34%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.07),transparent_30%)]"
    >
    </div>
    <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-white/10">
    </div>
    <div
        class="pointer-events-none absolute right-[-8%] bottom-[-22%] h-64 w-64 rounded-full bg-[#d8e6df]/10 blur-3xl transition-transform duration-700 group-hover:scale-110"
    >
    </div>

    <div
        class="relative z-10 grid h-full gap-7 lg:grid-cols-[minmax(0,1fr)_minmax(240px,300px)] lg:items-end"
    >
        <div class="space-y-5">
            <div class="space-y-4">
                <div class="flex items-center justify-between gap-4">
                    <div
                        class="flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 transition-colors duration-300 group-hover:bg-white/15"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-white/80"
                            aria-hidden="true"
                        >
                            <path d="M7 7v6a5 5 0 0 0 10 0V7"></path>
                            <path d="M7 17h10"></path>
                        </svg>
                    </div>
                    <div class="flex flex-wrap justify-end gap-2">
                        <span
                            class="inline-flex rounded-full border border-white/10 bg-white/10 px-3 py-1.5 font-sans text-[9px] font-semibold tracking-[0.2em] text-white/70 uppercase"
                        >
                            {campaign.label}
                        </span>
                        <span
                            class="inline-flex rounded-full border border-white/10 bg-[#31433c] px-3 py-1.5 font-sans text-[9px] font-semibold tracking-[0.2em] text-white/70 uppercase"
                        >
                            Ulule
                        </span>
                    </div>
                </div>

                <div class="space-y-3">
                    <h3
                        class="max-w-xl font-serif text-4xl leading-none text-white text-balance md:text-[3rem] lg:text-[3.35rem]"
                    >
                        {campaign.title}
                    </h3>
                    <p
                        class="max-w-2xl font-sans text-sm leading-relaxed text-white/70"
                    >
                        {campaign.subtitle}
                    </p>
                    <p
                        class="max-w-2xl font-sans text-sm leading-relaxed text-white/45"
                    >
                        {campaign.description}
                    </p>
                </div>
            </div>

            <div class="grid gap-3 sm:grid-cols-3">
                {
                    campaign.stats.map((stat) => (
                        <div class="rounded-2xl border border-white/10 bg-white/[0.07] px-4 py-4 transition-colors duration-300 group-hover:bg-white/[0.1]">
                            <p class="font-serif text-[1.55rem] leading-none text-white">
                                {stat.value}
                            </p>
                            <p class="mt-2 font-sans text-[8px] font-semibold tracking-[0.18em] text-white/55 uppercase">
                                {stat.label}
                            </p>
                        </div>
                    ))
                }
            </div>

            <div class="flex flex-wrap gap-2.5">
                <a
                    href={campaign.primaryHref}
                    target={campaign.primaryHref.startsWith("http")
                        ? "_blank"
                        : undefined}
                    rel={campaign.primaryHref.startsWith("http")
                        ? "noreferrer"
                        : undefined}
                    class="hero-chip-link inline-flex h-10 items-center rounded-full bg-white px-5 font-sans text-[9px] font-semibold tracking-[0.22em] text-[#31433c] uppercase hover:bg-[#edf4f0]"
                >
                    {campaign.primaryLabel}
                </a>
                {
                    campaign.secondaryHref && campaign.secondaryLabel && (
                        <a
                            href={campaign.secondaryHref}
                            class="hero-chip-link inline-flex h-10 items-center rounded-full border border-white/16 bg-transparent px-5 font-sans text-[9px] font-semibold tracking-[0.22em] text-white uppercase hover:border-white/30 hover:bg-white hover:text-[#31433c]"
                        >
                            {campaign.secondaryLabel}
                        </a>
                    )
                }
            </div>
        </div>

        <div class="relative min-h-[15rem] lg:min-h-[17rem]">
            <div
                class="pointer-events-none absolute inset-x-[14%] bottom-4 h-8 rounded-full bg-[#18201d]/30 blur-2xl"
            >
            </div>
            <div
                class="pointer-events-none absolute left-1/2 top-3 h-40 w-40 -translate-x-1/2 rounded-full bg-white/10 blur-3xl"
            >
            </div>
            <div
                class="absolute top-3 left-1/2 -translate-x-1/2 rounded-full bg-white/10 px-3 py-1.5 font-sans text-[8px] font-semibold tracking-[0.18em] text-white/60 uppercase"
            >
                En direct
            </div>

            <div class="absolute inset-x-0 bottom-0 flex justify-center">
                <div
                    class="w-full max-w-[17rem] rounded-2xl border border-white/10 bg-white/[0.06] p-4"
                >
                    <div
                        class="flex aspect-[4/5] items-center justify-center rounded-xl bg-[linear-gradient(180deg,#f7f1ec_0%,#ebe2dc_100%)] p-4 shadow-[0_34px_100px_-46px_rgba(0,0,0,0.58)] transition-all duration-700 group-hover:shadow-[0_42px_120px_-50px_rgba(0,0,0,0.62)]"
                    >
                        <img
                            src={campaign.coverSrc}
                            alt={campaign.coverAlt}
                            class="h-full w-auto max-w-full object-contain drop-shadow-[0_20px_30px_rgba(61,56,52,0.2)]"
                            loading="lazy"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hero-card {
        transition:
            transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
            box-shadow 400ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .hero-chip-link {
        transition:
            background-color 300ms cubic-bezier(0.16, 1, 0.3, 1),
            color 300ms cubic-bezier(0.16, 1, 0.3, 1),
            border-color 300ms cubic-bezier(0.16, 1, 0.3, 1),
            transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    @media (hover: hover) {
        .hero-card:hover {
            box-shadow: 0 32px 80px -40px rgba(11, 18, 15, 0.45);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-card,
        .hero-chip-link {
            transition-duration: 0.01ms !important;
            animation-duration: 0.01ms !important;
            transform: none !important;
        }
    }
</style>
