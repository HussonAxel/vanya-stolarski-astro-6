---
import { reviews } from "../data/reviews";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Reviews - Vanya Stolarski">
  <main class="overflow-hidden bg-[#FFFAFA] text-[#3d3834]">
    <section class="relative overflow-hidden bg-[#3d3834] px-6 py-24 text-[#FFFAFA]">
      <div class="relative mx-auto max-w-7xl">
        <a href="/" class="inline-flex items-center gap-3 font-sans text-[10px] font-bold tracking-[0.35em] text-[#3a4d45] uppercase">
          <span class="h-px w-10 bg-[#3a4d45]"></span>
          Retour a l'accueil
        </a>

        <div class="mt-10 grid gap-10 md:grid-cols-[1.15fr_0.85fr] md:items-end">
          <div class="space-y-6">
            <span class="inline-flex rounded-full border border-[#FFFAFA]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase">
              Presse & lectrices
            </span>
            <h1 class="max-w-4xl font-serif text-5xl leading-none md:text-7xl">
              Toutes les reviews dans une page plus ample, plus claire, plus contemporaine.
            </h1>
            <p class="max-w-2xl font-sans text-base leading-relaxed text-[#FFFAFA] md:text-lg">
              Cette page est concue comme un mur editorial: chaque review peut accueillir un extrait plus long, une source et des marqueurs visuels faciles a remplacer.
            </p>
          </div>

          <div class="section-panel fade-up rounded-[2rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-8 backdrop-blur-sm">
            <p class="font-serif text-6xl text-[#3a4d45]">{reviews.length}</p>
            <p class="mt-3 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase">
              Reviews placeholders prêtes a etre remplacees
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden bg-[#FFFAFA] px-6 py-20">
      <div class="mx-auto grid max-w-8xl gap-6 lg:grid-cols-2">
        {
          reviews.map((review, index) => (
            <article class:list={[
              "section-panel fade-up group relative overflow-hidden rounded-[2.35rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-8 shadow-[0_24px_80px_-48px_rgba(61,56,52,0.38)] backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 md:p-9",
              index % 3 === 0 ? "lg:col-span-2" : "",
            ]}>
              <div class="relative z-10 space-y-7">
                <div class="flex flex-wrap items-center justify-between gap-4">
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="rounded-full px-4 py-2 font-sans text-[10px] font-bold tracking-[0.25em] uppercase" style={`background:${review.accent}; color:#FFFAFA;`}>
                      {review.tag}
                    </span>
                    <span class="font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase">
                      {review.source}
                    </span>
                  </div>
                  <div class="flex gap-1" style={`color:${review.accent};`}>
                    {
                      Array.from({ length: review.rating }).map(() => (
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0">
                          <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z" />
                        </svg>
                      ))
                    }
                  </div>
                </div>

                <div class="grid gap-6 md:grid-cols-[1.1fr_0.9fr] md:items-start">
                  <blockquote class="font-serif text-3xl leading-relaxed md:text-4xl">
                    "{review.text}"
                  </blockquote>
                  <p class="font-sans text-base leading-relaxed text-[#3d3834]/78">
                    {review.excerpt}
                  </p>
                </div>

                <div class="flex flex-wrap items-center justify-between gap-4 border-t border-[#3d3834]/8 pt-5">
                  <div>
                    <p class="font-sans text-[10px] font-bold tracking-[0.25em] text-[#3a4d45] uppercase">
                      {review.book}
                    </p>
                    <p class="mt-2 font-sans text-sm text-[#3d3834]/78">
                      {review.author} - {review.date}
                    </p>
                  </div>
                  <a
                    href={`/livres/${review.bookSlug}`}
                    class="inline-flex items-center gap-3 rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-5 py-3 font-sans text-[10px] font-bold tracking-[0.24em] text-[#3d3834] uppercase transition-all duration-300 hover:-translate-y-1"
                  >
                    Voir le roman
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
