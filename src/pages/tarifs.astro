                  id="service-gallery-modal-image"
                  src=""
                  alt=""
                  class="block max-h-[68vh] max-w-full rounded-[1rem] object-contain md:max-h-[74vh] lg:max-h-[calc(92vh-8rem)]"
                />
              </div>
              <button
                type="button"
                id="service-gallery-modal-next"
                class="absolute right-0 top-1/2 z-10 inline-flex h-11 w-11  items-center justify-center rounded-full border border-[#FFFAFA]/14 bg-[#FFFAFA]/10 font-sans text-lg text-[#FFFAFA] backdrop-blur-sm transition-all duration-300 hover:bg-[#FFFAFA] hover:text-[#3d3834] disabled:pointer-events-none disabled:opacity-30"
                aria-label="Image suivante"
              >
                ›
              </button>
            </div>
          </div>

          <div class="min-h-0 overflow-y-auto p-6 md:p-8 lg:max-h-[92vh] lg:p-9">
            <div class="space-y-6">
              <div class="space-y-4">
                <div class="flex flex-wrap items-center gap-2.5">
                  <p id="service-gallery-modal-eyebrow" class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#3a4d45] uppercase"></p>
                  <span id="service-gallery-modal-price" class="inline-flex rounded-full border border-[#3d3834]/10 bg-[#fffaf8] px-3 py-1.5 font-sans text-[9px] font-bold tracking-[0.22em] text-[#3d3834]/70 uppercase"></span>
                </div>
                <div>
                  <h2 id="service-gallery-modal-title" class="font-serif text-3xl leading-none text-[#3d3834] text-balance md:text-4xl"></h2>
                  <p id="service-gallery-modal-service" class="mt-3 font-sans text-sm font-bold tracking-[0.2em] text-[#3d3834]/56 uppercase"></p>
                  <p id="service-gallery-modal-description" class="mt-4 font-sans text-sm leading-relaxed text-[#3d3834]/78 md:text-base"></p>
                </div>
              </div>

              <div class="rounded-[1.7rem] border border-[#3d3834]/10 bg-[#fffaf8] p-5">
                <p class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/58 uppercase">
                  Détails
                </p>
                <dl class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
                  <div class="space-y-1">
                    <dt class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/55 uppercase">Format</dt>
                    <dd id="service-gallery-modal-format" class="font-serif text-[1.45rem] leading-tight text-[#3d3834] break-words"></dd>
                  </div>
                  <div class="space-y-1">
                    <dt class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/55 uppercase">Adapté à</dt>
                    <dd id="service-gallery-modal-universe" class="font-serif text-[1.45rem] leading-tight text-[#3d3834] break-words"></dd>
                  </div>
                  <div class="space-y-1">
                    <dt class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/55 uppercase">Focus</dt>
                    <dd id="service-gallery-modal-focus" class="font-serif text-[1.45rem] leading-tight text-[#3d3834] break-words"></dd>
                  </div>
                  <div class="space-y-1">
                    <dt class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/55 uppercase">Dimensions</dt>
                    <dd id="service-gallery-modal-dimensions" class="font-serif text-[1.35rem] leading-tight text-[#3d3834]"></dd>
                  </div>
                </dl>
              </div>

              <div class="rounded-[1.7rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-5">
                <p class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/58 uppercase">
                  Note visuelle
                </p>
                <p id="service-gallery-modal-alt" class="mt-3 font-sans text-sm leading-relaxed text-[#3d3834]/78 md:text-[0.95rem]"></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── PROCESSUS & ENGAGEMENTS ─── -->
    <section class="relative overflow-hidden bg-[#FFFAFA] px-6 py-24">
      <div class="site-shell relative grid gap-8 xl:grid-cols-[minmax(0,1.04fr)_minmax(23rem,0.96fr)] xl:items-start">
        <div
          class="section-panel fade-up overflow-hidden rounded-[2.55rem] border border-[#3d3834]/10 bg-[linear-gradient(180deg,#4b443f_0%,#3d3834_100%)] p-8 text-[#FFFAFA] shadow-[0_30px_90px_-52px_rgba(61,56,52,0.46)] md:p-10 xl:p-12"
        >
          <p
            class="font-sans text-[10px] font-bold tracking-[0.35em] text-[#6f9184] uppercase"
          >
            Comment ça se passe
          </p>
          <h2 class="mt-5 max-w-4xl font-serif text-4xl leading-[0.94] text-balance md:text-5xl xl:text-[4.1rem]">
            Une base claire pour discuter du besoin, du rendu et du bon niveau
            de personnalisation.
          </h2>
          <p
            class="mt-6 max-w-2xl font-sans text-base leading-8 text-[#FFFAFA]/86 md:text-[1.02rem]"
          >
            Certains tarifs sont fixes, d'autres passent par un devis. Dans tous
            les cas, l'idée est de cadrer la demande avec précision pour que le
            visuel final soit cohérent avec ton univers de livre.
          </p>

          <div class="mt-10 space-y-3 border-t border-[#FFFAFA]/10 pt-8 md:mt-12 md:pt-9">
            {
              process.map((item) => (
                <div class="grid gap-4 rounded-[1.7rem] border border-[#FFFAFA]/10 bg-[#FFFAFA]/[0.04] px-4 py-4 md:grid-cols-[auto_1fr] md:items-start md:px-5">
                  <span class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-[#6f9184]/35 bg-[#6f9184]/10 font-serif text-2xl text-[#6f9184]">
                    {item.step}
                  </span>
                  <div class="space-y-2">
                    <p class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#FFFAFA]/82 uppercase">
                      {item.title}
                    </p>
                    <p class="font-sans text-sm leading-7 text-[#FFFAFA]/88 md:text-[0.98rem]">
                      {item.text}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="grid auto-rows-fr gap-4 md:grid-cols-2">
          {
            highlightedCommitments.map((item, index) => (
              <article
                class:list={[
                  "section-panel fade-up flex h-full flex-col rounded-[2rem] border p-7 shadow-[0_20px_70px_-45px_rgba(61,56,52,0.28)] backdrop-blur-sm md:p-8",
                  index === 2
                    ? "border-[#3a4d45]/14 bg-[linear-gradient(180deg,#f6efe9_0%,#fffaf8_100%)] md:col-span-2"
                    : "border-[#3d3834]/10 bg-[#FFFAFA]",
                ]}
              >
                <p class="font-sans text-[10px] font-bold tracking-[0.28em] text-[#3a4d45]/92 uppercase">
                  Repère
                </p>
                <h3 class="mt-5 max-w-[11ch] font-serif text-[2.35rem] leading-[0.92] text-[#3d3834] text-balance">
                  {item.title}
                </h3>
                <p class="mt-5 max-w-[26rem] font-sans text-[1rem] leading-8 text-[#3d3834]/84">
                  {item.text}
                </p>
                {
                  item.actionLabel && item.actionHref && (
                    <a
                      href={item.actionHref}
                      class="mt-auto inline-flex w-fit items-center gap-3 rounded-full border border-[#3a4d45]/14 bg-[#FFFAFA] px-5 py-3.5 font-sans text-[11px] font-bold tracking-[0.18em] text-[#3d3834] uppercase shadow-[0_14px_34px_-26px_rgba(61,56,52,0.35)] transition-all duration-300 hover:border-[#3a4d45]/30 hover:bg-[#3a4d45] hover:text-[#FFFAFA]"
                    >
                      {item.actionLabel}
                    </a>
                  )
                }
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── CTA FINAL ─── -->
    <section class="relative overflow-hidden bg-[#FFFAFA] px-6 py-24">
      <div class="site-shell relative mt-20">
        <div
          class="section-panel fade-up rounded-[2.5rem] border border-[#3d3834]/10 bg-[#3d3834] px-8 py-10 text-[#FFFAFA] shadow-[0_26px_90px_-55px_rgba(61,56,52,0.45)] md:px-10 md:py-12"
        >
          <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
            <div>
              <p
                class="font-sans text-[10px] font-bold tracking-[0.35em] text-[#3a4d45] uppercase"
              >
                Demande personnalisée
              </p>
              <h2 class="mt-4 font-serif text-4xl leading-none text-balance md:text-5xl">
                Pour toute demande personnalisée ou pour un devis, écris-moi
                directement.
              </h2>
              <p
                class="mt-4 max-w-2xl font-sans text-base leading-relaxed text-[#FFFAFA]"
              >
                Mail&nbsp;: {contact.email}<br />
                Instagram&nbsp;: {contact.instagramHandle}
              </p>
            </div>

            <div class="flex flex-wrap gap-3 lg:justify-end">
              <a
                href={`mailto:${contact.email}`}
                class="inline-flex items-center gap-3 rounded-full bg-[#3a4d45] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#FFFAFA] uppercase transition-all duration-300 hover:bg-[#FFFAFA] hover:text-[#3d3834]"
              >
                Envoyer un mail
              </a>
              <a
                href={contact.instagramUrl}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-3 rounded-full border border-[#FFFAFA]/12 bg-[#FFFAFA] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#3d3834] uppercase transition-all duration-300 hover:bg-[#FFFAFA]"
              >
                Ouvrir Instagram
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  [data-service-gallery-scroller]::-webkit-scrollbar {
    height: 12px;
  }

  [data-service-gallery-scroller]::-webkit-scrollbar-track {
    background: rgba(61, 56, 52, 0.08);
    border-radius: 999px;
  }

  [data-service-gallery-scroller]::-webkit-scrollbar-thumb {
    background: rgba(58, 77, 69, 0.58);
    border: 2px solid rgba(255, 253, 250, 0.95);
    border-radius: 999px;
  }

  [data-service-gallery-scroller]::-webkit-scrollbar-thumb:hover {
    background: rgba(58, 77, 69, 0.78);
  }
</style>

<script>
  const serviceGalleryTriggers = Array.from(
    document.querySelectorAll("[data-service-gallery-trigger]")
  );

  const serviceGalleryModal = document.getElementById("service-gallery-modal");
  const serviceGalleryModalImage = document.getElementById(
    "service-gallery-modal-image"
  );
  const serviceGalleryModalTitle = document.getElementById(
    "service-gallery-modal-title"
  );
  const serviceGalleryModalService = document.getElementById(
    "service-gallery-modal-service"
  );
  const serviceGalleryModalEyebrow = document.getElementById(
    "service-gallery-modal-eyebrow"
  );
  const serviceGalleryModalPrice = document.getElementById(
    "service-gallery-modal-price"
  );
  const serviceGalleryModalDescription = document.getElementById(
    "service-gallery-modal-description"
  );
  const serviceGalleryModalFormat = document.getElementById(
    "service-gallery-modal-format"
  );
  const serviceGalleryModalUniverse = document.getElementById(
    "service-gallery-modal-universe"
  );
  const serviceGalleryModalFocus = document.getElementById(
    "service-gallery-modal-focus"
  );
  const serviceGalleryModalDimensions = document.getElementById(
    "service-gallery-modal-dimensions"
  );
  const serviceGalleryModalAlt = document.getElementById(
    "service-gallery-modal-alt"
  );
  const serviceGalleryModalClose = document.getElementById(
    "service-gallery-modal-close"
  );
  const serviceGalleryModalPrev = document.getElementById(
    "service-gallery-modal-prev"
  );
  const serviceGalleryModalNext = document.getElementById(
    "service-gallery-modal-next"
  );
  const serviceGalleryModalCloseTargets = Array.from(
    document.querySelectorAll("[data-service-gallery-close]")
  );
  const serviceGalleryRoots = Array.from(
    document.querySelectorAll("[data-service-gallery-root]")
  );
  const serviceGalleryScrollers = Array.from(
    document.querySelectorAll("[data-service-gallery-scroller]")
  );

  let currentServiceGalleryIndex = -1;
  let lastServiceGalleryTrigger = null;

  const updateServiceGalleryNavigation = () => {
    const hasItems = serviceGalleryTriggers.length > 1;

    if (serviceGalleryModalPrev instanceof HTMLButtonElement) {
      serviceGalleryModalPrev.disabled = !hasItems;
    }

    if (serviceGalleryModalNext instanceof HTMLButtonElement) {
      serviceGalleryModalNext.disabled = !hasItems;
    }
  };

  const renderServiceGalleryModal = (index) => {
    const trigger = serviceGalleryTriggers[index];

    if (
      !(trigger instanceof HTMLElement) ||
      !(serviceGalleryModalImage instanceof HTMLImageElement) ||
      !(serviceGalleryModalTitle instanceof HTMLElement) ||
      !(serviceGalleryModalService instanceof HTMLElement) ||
      !(serviceGalleryModalEyebrow instanceof HTMLElement) ||
      !(serviceGalleryModalPrice instanceof HTMLElement) ||
      !(serviceGalleryModalDescription instanceof HTMLElement) ||
      !(serviceGalleryModalFormat instanceof HTMLElement) ||
      !(serviceGalleryModalUniverse instanceof HTMLElement) ||
      !(serviceGalleryModalFocus instanceof HTMLElement) ||
      !(serviceGalleryModalDimensions instanceof HTMLElement) ||
      !(serviceGalleryModalAlt instanceof HTMLElement)
    ) {
      return;
    }

    currentServiceGalleryIndex = index;

    const width = Number(trigger.dataset.width ?? 0);
    const height = Number(trigger.dataset.height ?? 0);

    serviceGalleryModalImage.src = trigger.dataset.image ?? "";
    serviceGalleryModalImage.alt = trigger.dataset.alt ?? "";
    serviceGalleryModalImage.width = width || 0;
    serviceGalleryModalImage.height = height || 0;

    serviceGalleryModalTitle.textContent = trigger.dataset.title ?? "";
    serviceGalleryModalService.textContent = trigger.dataset.service ?? "";
    serviceGalleryModalEyebrow.textContent = trigger.dataset.eyebrow ?? "";
    serviceGalleryModalPrice.textContent = trigger.dataset.price ?? "";
    serviceGalleryModalDescription.textContent =
      trigger.dataset.description ?? "";
    serviceGalleryModalFormat.textContent = trigger.dataset.format ?? "";
    serviceGalleryModalUniverse.textContent = trigger.dataset.universe ?? "";
    serviceGalleryModalFocus.textContent = trigger.dataset.focus ?? "";
    serviceGalleryModalAlt.textContent = trigger.dataset.alt ?? "";
    serviceGalleryModalDimensions.textContent =
      width && height ? `${width} x ${height}px` : "Format variable";

    updateServiceGalleryNavigation();
  };

  const openServiceGalleryModal = (index) => {
    if (!serviceGalleryModal || index < 0 || index >= serviceGalleryTriggers.length) {
      return;
    }

    const trigger = serviceGalleryTriggers[index];

    if (!(trigger instanceof HTMLElement)) {
      return;
    }

    lastServiceGalleryTrigger = trigger;
    renderServiceGalleryModal(index);

    serviceGalleryModal.classList.remove("pointer-events-none", "opacity-0");
    serviceGalleryModal.classList.add("opacity-100");
    serviceGalleryModal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";

    if (serviceGalleryModalClose instanceof HTMLButtonElement) {
      serviceGalleryModalClose.focus();
    }
  };

  const closeServiceGalleryModal = () => {
    if (!serviceGalleryModal) {
      return;
    }

    serviceGalleryModal.classList.add("pointer-events-none", "opacity-0");
    serviceGalleryModal.classList.remove("opacity-100");
    serviceGalleryModal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";

    if (lastServiceGalleryTrigger instanceof HTMLElement) {
      lastServiceGalleryTrigger.focus();
    }
  };

  const moveServiceGallery = (direction) => {
    if (!serviceGalleryTriggers.length) {
      return;
    }

    const nextIndex =
      (currentServiceGalleryIndex + direction + serviceGalleryTriggers.length) %
      serviceGalleryTriggers.length;

    renderServiceGalleryModal(nextIndex);
  };

  serviceGalleryTriggers.forEach((trigger, index) => {
    trigger.addEventListener("click", () => openServiceGalleryModal(index));
  });

  if (serviceGalleryModalClose instanceof HTMLButtonElement) {
    serviceGalleryModalClose.addEventListener("click", closeServiceGalleryModal);
  }

  if (serviceGalleryModalPrev instanceof HTMLButtonElement) {
    serviceGalleryModalPrev.addEventListener("click", () => moveServiceGallery(-1));
  }

  if (serviceGalleryModalNext instanceof HTMLButtonElement) {
    serviceGalleryModalNext.addEventListener("click", () => moveServiceGallery(1));
  }

  serviceGalleryModalCloseTargets.forEach((target) => {
    target.addEventListener("click", closeServiceGalleryModal);
  });

  document.addEventListener("keydown", (event) => {
    if (serviceGalleryModal?.getAttribute("aria-hidden") !== "false") {
      return;
    }

    if (event.key === "Escape") {
      closeServiceGalleryModal();
    }

    if (event.key === "ArrowLeft") {
      moveServiceGallery(-1);
    }

    if (event.key === "ArrowRight") {
      moveServiceGallery(1);
    }
  });

  const syncServiceGalleryScrollbar = (scroller, thumb) => {
    const maxScroll = scroller.scrollWidth - scroller.clientWidth;

    if (maxScroll <= 0) {
      thumb.style.width = "100%";
      thumb.style.transform = "translateX(0)";
      return;
    }

    const visibleRatio = scroller.clientWidth / scroller.scrollWidth;
    const thumbRatio = Math.min(Math.max(visibleRatio, 0.16), 0.72);
    const maxThumbTravel = 100 - thumbRatio * 100;
    const progress = scroller.scrollLeft / maxScroll;

    thumb.style.width = `${thumbRatio * 100}%`;
    thumb.style.transform = `translateX(${maxThumbTravel * progress}%)`;
  };

  serviceGalleryRoots.forEach((root) => {
    const scroller = root.querySelector("[data-service-gallery-scroller]");
    const thumb = root.querySelector("[data-service-gallery-scrollbar-thumb]");

    if (!(scroller instanceof HTMLElement) || !(thumb instanceof HTMLElement)) {
      return;
    }

    const updateThumb = () => syncServiceGalleryScrollbar(scroller, thumb);

    updateThumb();
    scroller.addEventListener("scroll", updateThumb, { passive: true });
    window.addEventListener("resize", updateThumb);
  });

  serviceGalleryScrollers.forEach((scroller) => {
    let isMouseDown = false;
    let startX = 0;
    let startScrollLeft = 0;
    let dragged = false;
    let suppressClick = false;

    scroller.addEventListener("mousedown", (event) => {
      if (!(event.target instanceof Element) || event.button !== 0) {
        return;
      }

      isMouseDown = true;
      dragged = false;
      startX = event.clientX;
      startScrollLeft = scroller.scrollLeft;
      scroller.classList.add("cursor-grabbing");
    });

    scroller.addEventListener("mousemove", (event) => {
      if (!isMouseDown) {
        return;
      }

      const deltaX = event.clientX - startX;

      if (Math.abs(deltaX) > 6) {
        dragged = true;
      }

      if (!dragged) {
        return;
      }

      event.preventDefault();
      scroller.scrollLeft = startScrollLeft - deltaX;
    });

    const endDrag = () => {
      if (!isMouseDown) {
        return;
      }

      isMouseDown = false;
      suppressClick = dragged;
      dragged = false;
      scroller.classList.remove("cursor-grabbing");
    };

    scroller.addEventListener("mouseleave", endDrag);
    document.addEventListener("mouseup", endDrag);

    scroller.addEventListener(
      "click",
      (event) => {
        if (!suppressClick) {
          return;
        }

        event.preventDefault();
        event.stopPropagation();
        suppressClick = false;
      },
      true
    );
  });
</script>
