---
import { latestBook } from "../data/books";
import BookGallery from "./BookGallery.astro";
import {
  getBookFormat,
  getBookGenres,
  getBookHook,
  getBookPages,
  getBookPrice,
  getBookPriceOptions,
  getBookReleaseDate,
  getBookSeries,
  getBookStatus,
  getBookTitle,
  getBookTome,
  getFeaturedBlock,
  getFeaturedGalleryItems,
} from "../lib/books";

const featured = getFeaturedBlock(latestBook);
const displayStatus =
  getBookStatus(latestBook) === "Disponible" ? "Publié" : getBookStatus(latestBook);
const galleryItems = getFeaturedGalleryItems(latestBook);
const priceOptions = getBookPriceOptions(latestBook);
---

<section class="relative overflow-hidden bg-[#fff7f3] py-14 md:py-16">
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute inset-x-0 top-0 h-28 bg-[linear-gradient(180deg,rgba(58,77,69,0.06),transparent)]"
    >
    </div>
    <div
      class="absolute right-0 top-[calc(50%-9rem)] h-72 w-72 translate-x-1/3 rounded-full bg-[#3a4d45]/8 blur-3xl"
    >
    </div>
  </div>

  <div class="site-shell relative z-10 px-6">
    <article
      class="fade-up mt-20 overflow-hidden rounded-[2.5rem] border border-[#3d3834]/10 bg-[#fffaf8] p-6 shadow-[0_34px_110px_-70px_rgba(61,56,52,0.34)] md:p-8 xl:p-9"
    >
      <div
        class="grid gap-7 xl:grid-cols-[minmax(0,1.06fr)_24rem] xl:items-stretch"
      >
        <div class="flex min-w-0 flex-col gap-6 xl:h-full">
          <div class="flex flex-wrap items-center gap-2.5">
            <span
              class="rounded-full bg-[#3a4d45] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.28em] text-[#FFFAFA] uppercase"
            >
              {displayStatus}
            </span>
            <span
              class="rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.28em] text-[#3d3834]/78 uppercase"
            >
              {featured?.label}
            </span>
            {
              getBookGenres(latestBook).map((genre) => (
                <span class="rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-3 py-1.5 font-sans text-[10px] font-bold tracking-[0.2em] text-[#3d3834]/70 uppercase">
                  {genre}
                </span>
              ))
            }
          </div>

          <div class="space-y-3">
            <p
              class="font-sans text-[10px] font-bold tracking-[0.34em] text-[#3d3834]/60 uppercase"
            >
              {getBookSeries(latestBook)} - {getBookTome(latestBook)}
            </p>
            <h2
              class="max-w-3xl font-serif text-4xl leading-[0.94] text-[#3d3834] text-balance md:text-5xl xl:text-[4.2rem]"
            >
              {getBookTitle(latestBook)}
            </h2>
            <p
              class="max-w-2xl font-sans text-base leading-relaxed text-[#3d3834]/82 md:text-lg italic"
            >
              {getBookHook(latestBook)}
            </p>
            <p
              class="max-w-2xl font-sans text-sm leading-relaxed text-[#3d3834]/68 md:text-[0.98rem]"
            >
              {featured?.shortPitch}
            </p>
          </div>

          <div class="mt-auto space-y-3.5">
            <div class="grid gap-3 sm:grid-cols-[11rem_minmax(0,1fr)]">
              <div class="rounded-[1.3rem] border border-[#3d3834]/8 bg-[#FFFAFA] px-4 py-3.5">
                <p class="font-sans text-[8px] font-bold tracking-[0.24em] text-[#3d3834]/46 uppercase">
                  Disponibilité
                </p>
                <p class="mt-1.5 font-serif text-[1.08rem] leading-tight text-[#3d3834]">
                  {getBookReleaseDate(latestBook)}
                </p>
              </div>
              <div class="rounded-[1.3rem] border border-[#3d3834]/8 bg-[#FFFAFA] px-4 py-3.5">
                <p class="font-sans text-[8px] font-bold tracking-[0.24em] text-[#3d3834]/46 uppercase">
                  Format
                </p>
                {
                  priceOptions.length ? (
                    <div class="mt-1.5 space-y-1">
                      <p class="font-serif text-[1.08rem] leading-tight text-[#3d3834]">
                        {getBookFormat(latestBook)}
                      </p>
                      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[#3d3834]">
                        {priceOptions.map((option) => (
                          <p class="font-serif text-[0.98rem] leading-tight">
                            <span class="text-[#3d3834]/58">{option.label}</span>{" "}
                            <span>{option.value}</span>
                          </p>
                        ))}
                      </div>
                    </div>
                  ) : (
                    <p class="mt-1.5 font-serif text-[1.08rem] leading-tight text-[#3d3834]">
                      {getBookFormat(latestBook)} · {getBookPrice(latestBook)}
                    </p>
                  )
                }
              </div>
            </div>

            <div class="flex flex-wrap gap-3">
              <a
                href={`/livres/${latestBook.slug}`}
                class="inline-flex items-center gap-3 rounded-full bg-[#3a4d45] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.24em] text-[#FFFAFA] uppercase transition-all duration-300 hover:bg-[#3d3834]"
              >
                Decouvrir le roman
              </a>
              <a
                href="/reviews"
                class="inline-flex items-center gap-3 rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.24em] text-[#3d3834] uppercase transition-all duration-300 hover:border-[#3a4d45]/35 hover:bg-[#3a4d45] hover:text-[#FFFAFA]"
              >
                Voir les avis
              </a>
            </div>
          </div>
        </div>

        <div class="flex h-full flex-col space-y-4 xl:pl-3">
          <BookGallery
            items={galleryItems}
            title={`Galerie ${getBookTitle(latestBook)}`}
          />
        </div>
      </div>
    </article>
  </div>
</section>
