---
import BookCardGallery from "../../components/BookCardGallery.astro";
import { books, latestBook } from "../../data/books";
import Layout from "../../layouts/Layout.astro";

const getBookStatusLabel = (status: string) => {
  if (status === "En ecriture") {
    return "En cours";
  }

  if (status === "Disponible") {
    return "Publie";
  }

  return status;
};

const getPrimaryStoreLink = (book: (typeof books)[number]) =>
  book.purchaseLinks?.find((link) => /sumup|boutique/i.test(link.label)) ??
  book.purchaseLinks?.[0];
---

<Layout title="Livres - Vanya Stolarski">
  <main class="bg-[#FFFAFA] text-[#3d3834]">
    <section
      class="relative overflow-hidden bg-[#3d3834] px-6 py-24 text-[#FFFAFA]"
    >
      <div class="site-shell relative flex flex-col gap-10">
        <div class="mt-20 grid gap-10 md:grid-cols-[1.3fr_0.7fr] md:items-end">
          <div class="space-y-6">
            <span
              class="inline-flex rounded-full border border-[#FFFAFA]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
            >
              Bibliotheque
            </span>
            <h1
              class="max-w-4xl font-serif text-5xl leading-none text-balance md:text-7xl"
            >
              Les histoires vivent ici, cruelles et douces à la fois, garnies de
              leur plus bel écrin deluxe. Vous y trouverez tant des récits
              historiques que fantastiques.
            </h1>
            <p
              class="max-w-2xl font-sans text-base leading-relaxed text-[#FFFAFA] md:text-lg"
            >
              Chaque fiche rassemble les couvertures, les informations clés, les
              genres, les liens d'achat et une présentation plus ample de chaque
              roman.
            </p>
          </div>

          <div
            class="fade-up rounded-lg border border-[#FFFAFA]/10 bg-[#FFFAFA] p-8 backdrop-blur-sm"
          >
            <div class="grid grid-cols-2 gap-6">
              <div>
                <p class="font-serif text-5xl text-[#3a4d45]">
                  {books.length}
                </p>
                <p
                  class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                >
                  Livres
                </p>
              </div>
              <div>
                <p class="font-serif text-5xl text-[#3a4d45]">
                  {latestBook.releaseDate}
                </p>
                <p
                  class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                >
                  Derniere parution
                </p>
              </div>
            </div>
            <a
              href={`/livres/${latestBook.slug}`}
              class="mt-8 inline-flex w-full items-center justify-between gap-3 rounded-lg border border-[#3d3834]/10 px-4 py-3 font-sans text-[11px] font-bold tracking-[0.2em] text-[#3d3834] uppercase transition-all duration-300 hover:border-[#3a4d45]/30 hover:text-[#3a4d45]"
              aria-label={`Ouvrir la fiche de ${latestBook.title}`}
            >
              Voir {latestBook.title}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-24">
      <div class="site-shell">
        <div class="grid gap-10 lg:grid-cols-3">
          {
            books.map((book, index) => {
              const galleryItems = book.gallery?.length
                ? book.gallery
                : [
                    {
                      src: book.cover,
                      alt: `Couverture de ${book.title}`,
                      label: "Couverture",
                    },
                  ];
              const storeLink = getPrimaryStoreLink(book);

              return (
                <article class="fade-up group flex h-full flex-col overflow-hidden rounded-lg border border-[#3d3834]/10 bg-[#FFFAFA] shadow-[0_24px_80px_-40px_rgba(61,56,52,0.45)]">
                  <div
                    class="relative overflow-hidden"
                    style={`background:${book.accent};`}
                  >
                    <BookCardGallery
                      items={galleryItems}
                      title={`Galerie ${book.title}`}
                    >
                      <div
                        slot="overlay"
                        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#3d3834]/45 via-transparent to-transparent"
                      />
                      <div
                        slot="overlay"
                        class="pointer-events-none absolute right-5 bottom-5 left-5 flex items-end justify-between gap-4"
                      >
                        <div>
                          <p class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#FFFAFA] uppercase">
                            {book.series}
                          </p>
                          <h2 class="mt-2 font-serif text-3xl text-[#FFFAFA] text-balance">
                            {book.title}
                          </h2>
                        </div>
                        <span class="rounded-full border border-[#FFFAFA]/20 bg-[#FFFAFA] px-3 py-1 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase">
                          {String(index + 1).padStart(2, "0")}
                        </span>
                      </div>
                    </BookCardGallery>
                  </div>

                  <div class="flex flex-1 flex-col gap-6 p-8">
                    <div class="flex flex-wrap gap-2">
                      {book.genres.map((genre) => (
                        <span class="rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-3 py-1 font-sans text-[10px] font-bold tracking-[0.12em] text-[#3d3834] uppercase">
                          {genre}
                        </span>
                      ))}
                    </div>

                    {book.slug === "coeur-de-renard" ? (
                      <div class="font-sans text-md text-center leading-relaxed text-[#3d3834]/78">
                        {book.description
                          .split("\n")
                          .filter(Boolean)
                          .map((line) => (
                            <p class="py-1.5">{line}</p>
                          ))}
                      </div>
                    ) : (
                      <p class="font-sans text-md text-center leading-relaxed whitespace-pre-line text-[#3d3834]/78">
                        {book.description}
                      </p>
                    )}

                    <div class="mt-auto flex flex-col gap-6">
                      <div class="grid grid-cols-3 gap-3 border-y border-[#3d3834]/10 py-5">
                        <div>
                          <p class="font-serif text-[1.7rem] leading-none md:text-[1.85rem]">
                            {book.pages ?? "—"}
                          </p>
                          <p class="font-sans text-[10px] font-bold tracking-[0.2em] text-[#3d3834] uppercase">
                            Pages
                          </p>
                        </div>

                        <div>
                          <p class="font-serif text-[1.55rem] leading-none md:text-[1.7rem]">
                            {getBookStatusLabel(book.status)}
                          </p>
                          <p class="font-sans text-[10px] font-bold tracking-[0.2em] text-[#3d3834] uppercase">
                            Statut
                          </p>
                        </div>
                        <div>
                          <p class="font-serif text-[1.55rem] leading-none md:text-[1.7rem]">
                            {book.tome.replace("Tome ", "T")}
                          </p>
                          <p class="font-sans text-[10px] font-bold tracking-[0.2em] text-[#3d3834] uppercase">
                            Format
                          </p>
                        </div>
                      </div>

                      <div class="flex flex-col gap-4">
                        <a
                          href={`/livres/${book.slug}`}
                          class="inline-flex w-full items-center justify-between gap-3 rounded-lg bg-[#3d3834] px-6 py-3 font-sans text-[11px] font-bold tracking-[0.25em] text-[#FFFAFA] uppercase transition-all duration-300"
                        >
                          Ouvrir la fiche
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <path d="M5 12h14" />
                            <path d="m12 5 7 7-7 7" />
                          </svg>
                        </a>

                        {storeLink && (
                          <a
                            href={storeLink.href}
                            target="_blank"
                            rel="noreferrer"
                            class="inline-flex w-full items-center justify-between gap-3 rounded-lg border border-[#3d3834]/10 bg-[#FFFAFA] px-6 py-3 font-sans text-[11px] font-bold tracking-[0.25em] text-[#3d3834] uppercase transition-all duration-300 hover:border-[#3a4d45]/30 hover:bg-[#3a4d45] hover:text-[#FFFAFA]"
                          >
                            {storeLink.label}
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="14"
                              height="14"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <path d="M7 7h10v10" />
                              <path d="M7 17 17 7" />
                            </svg>
                          </a>
                        )}

                        {book.chapterOneHref && (
                          <a
                            href={book.chapterOneHref}
                            download
                            class="inline-flex w-full items-center justify-between gap-3 rounded-lg border border-[#3d3834]/10 bg-[#FFFAFA] px-6 py-3 font-sans text-[11px] font-bold tracking-[0.25em] text-[#3d3834] uppercase transition-all duration-300 hover:border-[#3a4d45]/30 hover:bg-[#3a4d45] hover:text-[#FFFAFA]"
                          >
                            Telecharger le 1er chapitre
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="14"
                              height="14"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <path d="M12 3v12" />
                              <path d="m7 10 5 5 5-5" />
                              <path d="M5 21h14" />
                            </svg>
                          </a>
                        )}
                      </div>
                    </div>
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
