---
import type { BookGalleryItem } from "../data/books";

interface Props {
  items: BookGalleryItem[];
  title?: string;
}

const { items, title = "Galerie du livre" } = Astro.props as Props;
const galleryId = `gallery-${Math.random().toString(36).slice(2, 10)}`;
const slides = items.length > 0 ? items : [];
const hasMultiple = slides.length > 1;
const useContainFit = (src: string) => /Cover_CDR_Ulule\.png$/i.test(src);
---

<div
  class="book-gallery space-y-4"
  id={galleryId}
  data-gallery
  data-count={slides.length}
  aria-label={title}
>
  <div class="rounded-[1.85rem] border border-[#3d3834]/8 bg-[#FFFAFA] p-2.5 shadow-[0_32px_90px_-60px_rgba(61,56,52,0.45)]">
    <div class="relative overflow-hidden rounded-[1.55rem] bg-[#f6efec]">
      {
        slides.map((item, index) => (
          <figure
            class:list={[
              "book-gallery-slide",
              index === 0 ? "block" : "hidden",
            ]}
            data-slide
            data-index={index}
          >
            <img
              src={item.src}
              alt={item.alt}
              class:list={[
                "aspect-[4/4.9] w-full",
                useContainFit(item.src)
                  ? "bg-[#f6efec] p-4 object-contain"
                  : "object-cover",
              ]}
              loading={index === 0 ? "eager" : "lazy"}
            />
          </figure>
        ))
      }

      {
        hasMultiple && (
          <>
            <div class="pointer-events-none absolute left-3 top-3">
              <span class="pointer-events-auto rounded-full bg-[#fffaf8]/88 px-3 py-1.5 font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/70 uppercase backdrop-blur-sm" data-counter>
                1 / {slides.length}
              </span>
            </div>

            <div class="pointer-events-none absolute inset-x-0 inset-y-0 flex items-center justify-between px-3">
              <button
                type="button"
                class="pointer-events-auto inline-flex h-10 w-10 items-center justify-center rounded-full border border-[#FFFAFA]/16 bg-[#3d3834]/22 text-[#FFFAFA] backdrop-blur-sm transition-all duration-300 hover:border-[#FFFAFA]/28 hover:bg-[#fffaf8]/92 hover:text-[#3d3834]"
                data-prev
                aria-label="Image precedente"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m15 18-6-6 6-6" />
                </svg>
              </button>
              <button
                type="button"
                class="pointer-events-auto inline-flex h-10 w-10 items-center justify-center rounded-full border border-[#FFFAFA]/16 bg-[#3d3834]/22 text-[#FFFAFA] backdrop-blur-sm transition-all duration-300 hover:border-[#FFFAFA]/28 hover:bg-[#fffaf8]/92 hover:text-[#3d3834]"
                data-next
                aria-label="Image suivante"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </button>
            </div>
          </>
        )
      }
    </div>
  </div>

  {
    hasMultiple && (
      <div class="rounded-[1.4rem] border border-[#3d3834]/8 bg-[#FFFAFA] p-3 shadow-[0_20px_60px_-48px_rgba(61,56,52,0.35)]">
        <div class="space-y-2.5">
          <p class="font-sans text-[10px] font-bold tracking-[0.24em] text-[#3d3834]/58 uppercase">
            Choisir une vue
          </p>
          <div class="flex flex-wrap gap-2.5" role="tablist" aria-label={`${title} miniatures`}>
          {
            slides.map((item, index) => (
              <button
                type="button"
                class:list={[
                  "inline-flex items-center gap-2.5 rounded-full border px-4 py-2.5 text-left transition-all duration-300",
                  index === 0
                    ? "border-[#3a4d45]/22 bg-[#3a4d45] text-[#FFFAFA]"
                    : "border-[#3d3834]/10 bg-[#fffaf8] text-[#3d3834]/72 hover:border-[#3a4d45]/24 hover:bg-[#f3ece8]",
                ]}
                data-thumb
                data-index={index}
                aria-label={`Afficher ${item.label ?? `image ${index + 1}`}`}
                aria-selected={index === 0 ? "true" : "false"}
                role="tab"
              >
                <span class="inline-flex h-2.5 w-2.5 rounded-full bg-current opacity-50"></span>
                <span class="font-sans text-[10px] font-bold tracking-[0.18em] uppercase" data-thumb-label>
                  {item.label ?? `Vue ${index + 1}`}
                </span>
              </button>
            ))
          }
          </div>
        </div>
      </div>
    )
  }
</div>

<script>
  document.querySelectorAll("[data-gallery]").forEach((galleryRoot) => {
    if (!(galleryRoot instanceof HTMLElement)) {
      return;
    }

    if (galleryRoot.dataset.bound === "true") {
      return;
    }
    galleryRoot.dataset.bound = "true";

    const slides = Array.from(galleryRoot.querySelectorAll("[data-slide]"));
    const thumbs = Array.from(galleryRoot.querySelectorAll("[data-thumb]"));
    const prevButton = galleryRoot.querySelector("[data-prev]");
    const nextButton = galleryRoot.querySelector("[data-next]");
    const counter = galleryRoot.querySelector("[data-counter]");
    const label = galleryRoot.querySelector("[data-label]");

    if (slides.length <= 1) {
      return;
    }

    let currentIndex = 0;

    const update = (nextIndex) => {
      currentIndex = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, slideIndex) => {
        if (!(slide instanceof HTMLElement)) {
          return;
        }

        slide.classList.toggle("hidden", slideIndex !== currentIndex);
        slide.classList.toggle("block", slideIndex === currentIndex);
      });

      thumbs.forEach((thumb, thumbIndex) => {
        if (!(thumb instanceof HTMLElement)) {
          return;
        }

        thumb.classList.toggle("border-[#3a4d45]/22", thumbIndex === currentIndex);
        thumb.classList.toggle("bg-[#3a4d45]", thumbIndex === currentIndex);
        thumb.classList.toggle("text-[#FFFAFA]", thumbIndex === currentIndex);
        thumb.classList.toggle("border-[#3d3834]/10", thumbIndex !== currentIndex);
        thumb.classList.toggle("bg-[#fffaf8]", thumbIndex !== currentIndex);
        thumb.classList.toggle("text-[#3d3834]/72", thumbIndex !== currentIndex);
        thumb.setAttribute("aria-selected", String(thumbIndex === currentIndex));
      });

      const activeThumb = thumbs[currentIndex];
      if (counter instanceof HTMLElement) {
        counter.textContent = `${currentIndex + 1} / ${slides.length}`;
      }
      if (label instanceof HTMLElement && activeThumb instanceof HTMLElement) {
        const thumbLabel = activeThumb.querySelector("[data-thumb-label]");
        label.textContent = thumbLabel?.textContent?.trim() || `Vue ${currentIndex + 1}`;
      }

      galleryRoot.dispatchEvent(
        new CustomEvent("book-gallery:change", {
          bubbles: true,
          detail: { index: currentIndex },
        }),
      );
    };

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        if (!(thumb instanceof HTMLElement)) {
          return;
        }
        const nextIndex = Number(thumb.dataset.index ?? 0);
        update(nextIndex);
      });
    });

    if (prevButton instanceof HTMLButtonElement) {
      prevButton.addEventListener("click", () => update(currentIndex - 1));
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.addEventListener("click", () => update(currentIndex + 1));
    }

    update(0);
  });
</script>
