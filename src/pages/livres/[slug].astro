---
import { books } from "../../data/books";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const relatedBooks = books.filter((entry) => entry.slug !== book.slug).slice(0, 2);
---

<Layout title={`${book.title} - Vanya Stolarski`}>
  <main class="bg-[#FFFAFA] text-[#3d3834]">
    <section class="relative overflow-hidden bg-[#3d3834] px-6 py-20 text-[#FFFAFA] md:py-24">
      <div class="relative mx-auto max-w-7xl">
        <div class="mb-12 flex flex-wrap items-center gap-4 font-sans text-[10px] font-bold tracking-[0.3em] text-[#3a4d45] uppercase">
          <a href="/" class="transition-opacity hover:opacity-70">Accueil</a>
          <span class="text-[#FFFAFA]/20">/</span>
          <a href="/livres" class="transition-opacity hover:opacity-70">Livres</a>
          <span class="text-[#FFFAFA]/20">/</span>
          <span>{book.title}</span>
        </div>

        <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
          <div class="fade-up relative mx-auto w-full max-w-md">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-4 shadow-2xl backdrop-blur-sm">
              <img
                src={book.cover}
                alt={`Couverture de ${book.title}`}
                class="aspect-[4/5] w-full rounded-[2rem] object-cover"
              />
            </div>
          </div>

          <div class="space-y-8">
            <div class="space-y-5">
              <span class="inline-flex rounded-full border border-[#FFFAFA]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase">
                {book.series}
              </span>
              <div>
                <p class="font-sans text-[10px] font-bold tracking-[0.35em] text-[#FFFAFA] uppercase">
                  {book.tome}
                </p>
                <h1 class="mt-3 max-w-4xl font-serif text-5xl leading-none md:text-7xl">
                  {book.title}
                </h1>
              </div>
                <p class="max-w-2xl font-sans text-lg leading-relaxed text-[#FFFAFA]">
                {book.hook}
              </p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
              <div class="rounded-[1.5rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-5 backdrop-blur-sm">
                <p class="font-serif text-3xl">{book.pages}</p>
                <p class="mt-2 font-sans text-[10px] font-bold tracking-[0.24em] text-[#3d3834] uppercase">Pages</p>
              </div>
              <div class="rounded-[1.5rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-5 backdrop-blur-sm">
                <p class="font-serif text-3xl">{book.price}</p>
                <p class="mt-2 font-sans text-[10px] font-bold tracking-[0.24em] text-[#3d3834] uppercase">Tarif</p>
              </div>
              <div class="rounded-[1.5rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-5 backdrop-blur-sm">
                <p class="font-serif text-2xl">{book.releaseDate}</p>
                <p class="mt-2 font-sans text-[10px] font-bold tracking-[0.24em] text-[#3d3834] uppercase">Parution</p>
              </div>
              <div class="rounded-[1.5rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-5 backdrop-blur-sm">
                <p class="font-serif text-2xl">{book.status}</p>
                <p class="mt-2 font-sans text-[10px] font-bold tracking-[0.24em] text-[#3d3834] uppercase">Statut</p>
              </div>
            </div>

            <!-- <div class="flex flex-wrap gap-3">
              <a
                href="#newsletter"
                class="inline-flex items-center gap-3 rounded-full bg-[#3a4d45] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.24em] text-[#3d3834] uppercase transition-all duration-300 hover:-translate-y-1"
              >
                Recevoir les nouvelles
              </a>
              <a
                href="/livres"
                class="inline-flex items-center gap-3 rounded-full border border-[#FFFAFA]/15 bg-[#FFFAFA] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.24em] text-[#FFFAFA] uppercase transition-all duration-300 hover:-translate-y-1"
              >
                Retour aux livres
              </a>
            </div> -->
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-24">
      <div class="mx-auto grid max-w-8xl gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <article class="fade-up rounded-[2rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-10 shadow-[0_24px_80px_-40px_rgba(61,56,52,0.45)]">
          <div class="mb-8 flex items-center gap-3">
            <span class="h-px w-10 bg-[#3a4d45]"></span>
            <p class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#3a4d45] uppercase">
              Synopsis long
            </p>
          </div>
          <div class="space-y-6">
            <h2 class="font-serif text-4xl">Une fiche modifiable pour presenter le livre en profondeur.</h2>
            <p class="font-sans text-base leading-relaxed text-[#3d3834]/72">
              {book.longDescription}
            </p>
            <p class="font-sans text-base leading-relaxed text-[#3d3834]/72">
              Placeholder additionnel. Cette zone peut accueillir un second paragraphe de quatrieme de couverture, des notes d'intention ou un extrait de presentation presse.
            </p>
          </div>
        </article>

        <aside class="fade-up rounded-[2rem] border border-[#3d3834]/10 bg-[#3a4d45] p-10 text-[#FFFAFA] shadow-[0_24px_80px_-40px_rgba(61,56,52,0.45)]">
          <div class="mb-8 flex items-center gap-3">
            <span class="h-px w-10 bg-[#FFFAFA]"></span>
            <p class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#FFFAFA] uppercase">
              Citation
            </p>
          </div>
          <blockquote class="font-serif text-3xl leading-relaxed italic">
            "{book.quote}"
          </blockquote>
          <p class="mt-8 font-sans text-sm leading-relaxed text-[#FFFAFA]">
            Placeholder note. Vous pourrez remplacer cet encart par une recommandation, un extrait de chronique ou une phrase de l'autrice.
          </p>
        </aside>
      </div>
    </section>

    <section class="bg-[#FFFAFA] px-6 py-24">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
          <div class="fade-up rounded-[2rem] border border-[#3d3834]/10 bg-[#3d3834] p-10 text-[#FFFAFA]">
            <p class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#3a4d45] uppercase">
              Infos rapides
            </p>
            <h2 class="mt-4 font-serif text-4xl">Des blocs clairs pour vos futures vraies donnees.</h2>
            <p class="mt-4 font-sans text-sm leading-relaxed text-[#FFFAFA]">
              ISBN, formats, statut, personnages, ambiance, tropes: tout est deja structure pour que vous puissiez remplacer le placeholder sans toucher a l'architecture.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            {book.details.map((detail) => (
              <div class="fade-up rounded-[1.75rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-6 shadow-[0_24px_60px_-45px_rgba(61,56,52,0.45)]">
                <p class="font-sans text-[10px] font-bold tracking-[0.25em] text-[#3a4d45] uppercase">
                  {detail.label}
                </p>
                <p class="mt-4 font-serif text-3xl leading-tight text-[#3d3834]">
                  {detail.value}
                </p>
              </div>
            ))}
            <div class="fade-up rounded-[1.75rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-6 shadow-[0_24px_60px_-45px_rgba(61,56,52,0.45)]">
              <p class="font-sans text-[10px] font-bold tracking-[0.25em] text-[#3a4d45] uppercase">
                Format
              </p>
              <p class="mt-4 font-serif text-3xl leading-tight text-[#3d3834]">
                {book.format}
              </p>
            </div>
            <div class="fade-up rounded-[1.75rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-6 shadow-[0_24px_60px_-45px_rgba(61,56,52,0.45)]">
              <p class="font-sans text-[10px] font-bold tracking-[0.25em] text-[#3a4d45] uppercase">
                Genres
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                {book.genres.map((genre) => (
                  <span class="rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-3 py-1 font-sans text-[10px] font-bold tracking-[0.12em] text-[#3d3834] uppercase">
                    {genre}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-24" id="newsletter">
      <div class="mx-auto max-w-8xl rounded-[2.5rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-10 shadow-[0_24px_80px_-40px_rgba(61,56,52,0.45)] md:p-14">
        <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-center">
          <div>
            <p class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#3a4d45] uppercase">
              Appel a l'action
            </p>
            <h2 class="mt-4 font-serif text-4xl text-[#3d3834] md:text-5xl">
              Gardez une section newsletter directement sur chaque page livre.
            </h2>
            <p class="mt-5 max-w-2xl font-sans text-base leading-relaxed text-[#3d3834]/72">
              Placeholder. Vous pouvez ici brancher votre formulaire, annoncer des bonus lecteurs ou parler des prochaines sorties.
            </p>
          </div>

          <form class="grid gap-3 rounded-[2rem] bg-[#FFFAFA] p-6">
            <input
              type="email"
              required
              placeholder="Votre adresse email"
              class="rounded-2xl border border-[#3d3834]/15 bg-transparent px-4 py-4 font-sans text-sm text-[#3d3834] outline-none transition-colors placeholder:text-[#3d3834]/35 focus:border-[#3a4d45]"
            />
            <button
              type="submit"
              class="rounded-2xl bg-[#3d3834] px-5 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#FFFAFA] uppercase transition-all duration-300 hover:bg-[#3a4d45] hover:text-[#3d3834]"
            >
              M'avertir des nouvelles
            </button>
              <p class="font-sans text-[11px] leading-relaxed text-[#3d3834]/78">
              Texte placeholder pour le consentement, la frequence d'envoi ou les avantages de l'inscription.
            </p>
          </form>
        </div>
      </div>
    </section>

    {relatedBooks.length > 0 && (
      <section class="bg-[#3d3834] px-6 py-24 text-[#FFFAFA]">
        <div class="mx-auto max-w-7xl">
          <div class="mb-12 flex items-end justify-between gap-6">
            <div>
              <p class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#3a4d45] uppercase">
                Continuer la visite
              </p>
              <h2 class="mt-4 font-serif text-4xl">Autres livres a explorer</h2>
            </div>
            <a href="/livres" class="font-sans text-[10px] font-bold tracking-[0.25em] text-[#FFFAFA] uppercase transition-opacity hover:opacity-70">
              Voir la bibliotheque complete
            </a>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            {relatedBooks.map((entry) => (
              <a
                href={`/livres/${entry.slug}`}
                class="fade-up group grid gap-6 overflow-hidden rounded-[2rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-6 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 md:grid-cols-[180px_1fr]"
              >
                <img
                  src={entry.cover}
                  alt={`Couverture de ${entry.title}`}
                  loading="lazy"
                  class="aspect-[4/5] h-full w-full rounded-[1.5rem] object-cover"
                />
                <div class="flex flex-col justify-between gap-5">
                  <div>
                    <p class="font-sans text-[10px] font-bold tracking-[0.25em] text-[#3a4d45] uppercase">
                      {entry.series}
                    </p>
                    <h3 class="mt-3 font-serif text-3xl">{entry.title}</h3>
                    <p class="mt-4 font-sans text-sm leading-relaxed text-[#3d3834]">
                      {entry.description}
                    </p>
                  </div>
                  <span class="inline-flex items-center gap-3 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase">
                    Ouvrir la fiche
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="transition-transform duration-300 group-hover:translate-x-1"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>
