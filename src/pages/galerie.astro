---
import Layout from "../layouts/Layout.astro";
import {
  galleryItems,
  getGalleryArtistFilters,
  getGalleryBookFilters,
} from "../data/gallery";
import { getBookBySlug, getBookTitle } from "../lib/books";

const galleryArtistFilters = getGalleryArtistFilters(galleryItems);
const galleryBookFilters = getGalleryBookFilters(galleryItems);
const galleryBookFilterLabels = Object.fromEntries(
  galleryBookFilters
    .filter((filter) => filter !== "all")
    .map((filter) => {
      const book = getBookBySlug(filter);
      return [filter, book ? getBookTitle(book) : filter];
    }),
);
---

<Layout title="Galerie - Vanya Stolarski">
    <main class="overflow-hidden bg-[#FFFAFA] text-[#3d3834]">
        <section
            class="relative overflow-hidden bg-[#3d3834] px-6 py-24 text-[#FFFAFA]"
        >
            <div class="site-shell relative mt-20">
                <div
                    class="mt-10 grid gap-10 md:grid-cols-[1.15fr_0.85fr] md:items-end"
                >
                    <div class="space-y-6">
                        <span
                            class="inline-flex rounded-full border border-[#FFFAFA]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                        >
                            Galerie éditoriale
                        </span>
                        <h1
                            class="max-w-4xl font-serif text-5xl leading-none text-balance md:text-7xl"
                        >
                            J'y rassemble les visages, les gestes et les
                            tensions qui continuent de me suivre.
                        </h1>
                        <p
                            class="max-w-2xl font-sans text-base leading-relaxed text-[#FFFAFA] md:text-lg"
                        >
                            Les images se lisent d'abord comme une matiere
                            visuelle. Au clic, chaque illustration s'ouvre dans
                            une fiche plus détaillée avec son contexte et son
                            rattachement au roman.
                        </p>
                    </div>

                    <div
                        class="section-panel fade-up rounded-lg border border-[#FFFAFA]/10 bg-[#FFFAFA] p-8 backdrop-blur-sm"
                    >
                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <p class="font-serif text-5xl text-[#3a4d45]">
                                    {galleryItems.length}
                                </p>
                                <p
                                    class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                                >
                                    Visuels
                                </p>
                            </div>
                            <div>
                                <p class="font-serif text-5xl text-[#3a4d45]">
                                    {galleryArtistFilters.length - 1}
                                </p>
                                <p
                                    class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                                >
                                    Artistes
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section
            class="relative overflow-hidden bg-[#FFFAFA] px-6 py-16 md:py-20"
        >
            <div class="site-shell relative space-y-8">
                <div
                    class="section-panel fade-up rounded-[1.8rem] border border-[#3d3834]/10 p-4 shadow-[0_20px_70px_-45px_rgba(61,56,52,0.3)] backdrop-blur-sm md:p-5"
                >
                    <div class="space-y-5">
                        <div
                            class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between"
                        >
                            <div class="flex flex-wrap items-center gap-3">
                                <p
                                    data-gallery-results
                                    class="rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/72 uppercase"
                                    aria-live="polite"
                                >
                                    15 visuels disponibles
                                </p>
                                <button
                                    type="button"
                                    data-gallery-reset
                                    class="inline-flex items-center gap-2 rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834] uppercase transition-all duration-300 hover:border-[#3a4d45]/35 hover:text-[#3a4d45] disabled:cursor-not-allowed disabled:opacity-45"
                                >
                                    Réinitialiser
                                </button>
                            </div>
                        </div>

                        <div class="grid gap-3 lg:grid-cols-2">
                            <section
                                class="rounded-[1.35rem] border border-[#3d3834]/10 bg-[#FFFAFA]/80 p-4"
                            >
                                <div
                                    class="mb-3 flex items-center justify-between gap-3"
                                >
                                    <div>
                                        <p
                                            id="gallery-book-filter-label"
                                            class="font-sans text-[10px] font-bold tracking-[0.24em] text-[#3d3834]/50 uppercase"
                                        >
                                            Romans
                                        </p>
                                        <p
                                            class="mt-1 font-sans text-sm text-[#3d3834]/68"
                                        >
                                            Partir d'un univers puis ne garder
                                            que les artistes.
                                        </p>
                                    </div>
                                </div>
                                <div
                                    class="flex flex-wrap gap-2"
                                    data-filter-group="book"
                                    aria-labelledby="gallery-book-filter-label"
                                >
                                    {
                                        galleryBookFilters.map((filter) => (
                                            <button
                                                type="button"
                                                data-book-filter={filter}
                                                data-filter-kind="book"
                                                data-active={
                                                    filter === "all"
                                                        ? "true"
                                                        : "false"
                                                }
                                                class="gallery-filter inline-flex items-center gap-2 rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-3 py-2 font-sans text-[11px] font-bold tracking-[0.18em] text-[#3d3834] uppercase transition-all duration-300"
                                                aria-label={
                                                    filter === "all"
                                                        ? "Afficher tous les romans"
                                                        : `Filtrer par ${galleryBookFilterLabels[filter]}`
                                                }
                                            >
                                                <span>
                                                    {filter === "all"
                                                        ? "Tout"
                                                        : galleryBookFilterLabels[
                                                              filter
                                                          ]}
                                                </span>
                                                <span
                                                    data-filter-count
                                                    class="inline-flex min-w-[1.4rem] items-center justify-center rounded-full bg-[#3d3834]/6 px-1.5 py-1 text-[8px] leading-none tracking-normal text-[#3d3834]/55"
                                                >
                                                    0
                                                </span>
                                            </button>
                                        ))
                                    }
                                </div>
                            </section>

                            <section
                                class="rounded-[1.35rem] border border-[#3d3834]/10 bg-[#FFFAFA]/80 p-4"
                            >
                                <div
                                    class="mb-3 flex items-center justify-between gap-3"
                                >
                                    <div>
                                        <p
                                            id="gallery-artist-filter-label"
                                            class="font-sans text-[10px] font-bold tracking-[0.24em] text-[#3d3834]/50 uppercase"
                                        >
                                            Artistes
                                        </p>
                                        <p
                                            class="mt-1 font-sans text-sm text-[#3d3834]/68"
                                        >
                                            Voir tout un regard ou croiser avec
                                            un roman sans tomber sur une grille
                                            vide.
                                        </p>
                                    </div>
                                </div>
                                <div
                                    class="flex flex-wrap gap-2"
                                    data-filter-group="artist"
                                    aria-labelledby="gallery-artist-filter-label"
                                >
                                    {
                                        galleryArtistFilters.map((filter) => (
                                            <button
                                                type="button"
                                                data-artist-filter={filter}
                                                data-filter-kind="artist"
                                                data-active={
                                                    filter === "all"
                                                        ? "true"
                                                        : "false"
                                                }
                                                class="gallery-filter inline-flex items-center gap-2 rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-3 py-2 font-sans text-[11px] font-bold tracking-[0.18em] text-[#3d3834] uppercase transition-all duration-300"
                                                aria-label={
                                                    filter === "all"
                                                        ? "Afficher tous les artistes"
                                                        : `Filtrer par ${filter}`
                                                }
                                            >
                                                <span>
                                                    {filter === "all"
                                                        ? "Tout"
                                                        : filter}
                                                </span>
                                                <span
                                                    data-filter-count
                                                    class="inline-flex min-w-[1.4rem] items-center justify-center rounded-full bg-[#3d3834]/6 px-1.5 py-1 text-[8px] leading-none tracking-normal text-[#3d3834]/55"
                                                >
                                                    0
                                                </span>
                                            </button>
                                        ))
                                    }
                                </div>
                            </section>
                        </div>
                    </div>
                </div>

                <div class="w-full">
                    <div
                        id="gallery-grid"
                        class="gallery-columns columns-1 gap-4 sm:columns-2 xl:columns-4"
                    >
                        {
                            galleryItems.map((item) => (
                                <button
                                    type="button"
                                    class="gallery-item gallery-card fade-up group relative mb-4 block w-full break-inside-avoid overflow-hidden rounded-[1.35rem] border border-[#3d3834]/8 bg-[#FFFAFA] shadow-[0_24px_80px_-52px_rgba(61,56,52,0.45)] transition-all duration-300 hover:shadow-[0_30px_90px_-52px_rgba(61,56,52,0.5)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3a4d45]"
                                    data-book={item.bookSlug}
                                    data-artist={item.artist}
                                    data-gallery-trigger
                                    data-title={item.title}
                                    data-image={item.image}
                                    data-alt={item.alt}
                                    data-book-label={galleryBookFilterLabels[item.bookSlug] ?? item.bookSlug}
                                    data-book-href={`/livres/${item.bookSlug}`}
                                    data-artist-label={item.artist}
                                    data-date={item.date}
                                    data-description={item.description}
                                    aria-label={`Ouvrir la fiche de ${item.title}`}
                                >
                                    <div class="relative overflow-hidden bg-[#FFFAFA]">
                                        <img
                                            src={item.image}
                                            alt={item.alt}
                                            loading="lazy"
                                            class="w-full rounded-[1.35rem] object-cover transition-transform duration-700 group-hover:scale-[1.025]"
                                        />
                                    </div>
                                </button>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <div
            id="gallery-modal"
            class="pointer-events-none fixed inset-0 z-50 flex items-start justify-center overflow-y-auto bg-[#3d3834]/72 px-4 py-4 opacity-0 transition-all duration-300 md:items-center md:py-8"
            role="dialog"
            aria-modal="true"
            aria-labelledby="gallery-modal-title"
            aria-hidden="true"
        >
            <div data-gallery-close class="absolute inset-0"></div>
            <div
                class="relative z-10 my-auto w-full max-w-[min(96vw,1380px)] overflow-hidden rounded-[2.2rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] shadow-[0_35px_120px_-50px_rgba(61,56,52,0.6)] lg:max-h-[92vh]"
            >
                <button
                    type="button"
                    id="gallery-modal-close"
                    class="absolute top-4 right-4 z-20 inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#3d3834]/10 bg-[#FFFAFA]/92 font-sans text-xs font-bold tracking-[0.2em] text-[#3d3834] uppercase shadow-[0_10px_30px_-24px_rgba(61,56,52,0.55)] transition-all duration-300 hover:border-[#3a4d45]/30 hover:bg-[#3a4d45] hover:text-[#FFFAFA]"
                    aria-label="Fermer la popup"
                >
                    X
                </button>

                <div
                    class="grid lg:grid-cols-[minmax(0,1fr)_400px] lg:items-stretch"
                >
                    <div
                        class="relative flex min-h-[38vh] items-center justify-center overflow-hidden bg-[#3d3834] p-3 md:min-h-[48vh] md:p-4 lg:min-h-0 lg:p-5"
                    >
                        <div
                            class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,250,248,0.08),transparent_56%)]"
                        >
                        </div>
                        <div
                            class="relative inline-flex h-full w-full max-w-full items-center justify-center overflow-hidden rounded-[1.55rem] border border-[#FFFAFA]/8 bg-[#312d2a] p-3 shadow-[0_24px_60px_-45px_rgba(61,56,52,0.45)] md:p-4"
                        >
                            <img
                                id="gallery-modal-image"
                                src=""
                                alt=""
                                class="block max-h-[58vh] max-w-full rounded-[1rem] object-contain md:max-h-[72vh] lg:max-h-[calc(92vh-5.5rem)]"
                            />
                        </div>
                    </div>

                    <div
                        class="min-h-0 overflow-y-auto p-6 md:p-8 lg:max-h-[92vh] lg:p-9"
                    >
                        <div class="space-y-6">
                            <div class="space-y-4">
                                <div
                                    class="flex flex-wrap items-center gap-2.5"
                                >
                                    <p
                                        id="gallery-modal-artist"
                                        class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#3d3834] uppercase"
                                    >
                                    </p>
                                    <span
                                        class="inline-flex rounded-full border border-[#3d3834]/10 bg-[#fffaf8] px-3 py-1.5 font-sans text-[9px] font-bold tracking-[0.22em] text-[#3d3834]/70 uppercase"
                                    >
                                        Illustration
                                    </span>
                                </div>
                                <div>
                                    <h2
                                        id="gallery-modal-title"
                                        class="font-serif text-3xl leading-none text-balance md:text-4xl"
                                    >
                                    </h2>
                                    <p
                                        id="gallery-modal-description"
                                        class="mt-4 font-sans text-sm leading-relaxed text-[#3d3834]/78 md:text-base"
                                    >
                                    </p>
                                </div>
                            </div>

                            <div
                                class="rounded-[1.7rem] border border-[#3d3834]/10 bg-[#fffaf8] p-5"
                            >
                                <p
                                    class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/58 uppercase"
                                >
                                    Contexte
                                </p>
                                <dl
                                    class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-1"
                                >
                                    <div class="space-y-1">
                                        <dt
                                            class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/55 uppercase"
                                        >
                                            Roman
                                        </dt>
                                        <dd
                                            id="gallery-modal-book"
                                            class="font-serif text-[1.55rem] leading-tight text-[#3d3834] break-words"
                                        >
                                        </dd>
                                    </div>
                                    <div class="space-y-1">
                                        <dt
                                            class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/55 uppercase"
                                        >
                                            Artiste
                                        </dt>
                                        <dd
                                            id="gallery-modal-artist-detail"
                                            class="font-serif text-[1.45rem] leading-tight text-[#3d3834] break-words"
                                        >
                                        </dd>
                                    </div>
                                    <div
                                        class="space-y-1 sm:col-span-2 lg:col-span-1"
                                    >
                                        <dt
                                            class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/55 uppercase"
                                        >
                                            Date
                                        </dt>
                                        <dd
                                            id="gallery-modal-date"
                                            class="font-serif text-[1.45rem] leading-tight text-[#3d3834]"
                                        >
                                        </dd>
                                    </div>
                                </dl>
                            </div>

                            <div
                                class="rounded-[1.7rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-5"
                            >
                                <p
                                    class="font-sans text-[10px] font-bold tracking-[0.22em] text-[#3d3834]/58 uppercase"
                                >
                                    Note visuelle
                                </p>
                                <p
                                    id="gallery-modal-alt"
                                    class="mt-3 font-sans text-sm leading-relaxed text-[#3d3834]/78 md:text-[0.95rem]"
                                >
                                </p>
                            </div>

                            <div class="flex flex-wrap gap-3 pt-1">
                                <a
                                    id="gallery-modal-link"
                                    href="#"
                                    class="inline-flex items-center gap-3 rounded-full bg-[#3d3834] px-6 py-4 font-sans text-[11px] font-bold tracking-[0.24em] text-[#FFFAFA] uppercase transition-all duration-300 hover:bg-[#3a4d45]"
                                >
                                    Voir le roman
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script>
            const state = { book: "all", artist: "all" };

            const itemEls = Array.from(
                document.querySelectorAll(".gallery-item"),
            );
            const bookButtons = Array.from(
                document.querySelectorAll("[data-book-filter]"),
            );
            const artistButtons = Array.from(
                document.querySelectorAll("[data-artist-filter]"),
            );
            const resultSummary = document.querySelector(
                "[data-gallery-results]",
            );
            const resetButton = document.querySelector("[data-gallery-reset]");

            const modal = document.getElementById("gallery-modal");
            const modalImage = document.getElementById("gallery-modal-image");
            const modalTitle = document.getElementById("gallery-modal-title");
            const modalArtist = document.getElementById("gallery-modal-artist");
            const modalDescription = document.getElementById(
                "gallery-modal-description",
            );
            const modalBook = document.getElementById("gallery-modal-book");
            const modalArtistDetail = document.getElementById(
                "gallery-modal-artist-detail",
            );
            const modalDate = document.getElementById("gallery-modal-date");
            const modalAlt = document.getElementById("gallery-modal-alt");
            const modalLink = document.getElementById("gallery-modal-link");
            const modalCloseButtons = Array.from(
                document.querySelectorAll("[data-gallery-close]"),
            );
            const modalCloseButton = document.getElementById(
                "gallery-modal-close",
            );
            let lastTrigger = null;

            const getItemMatches = (bookValue, artistValue) =>
                itemEls.filter((item) => {
                    const matchesBook =
                        bookValue === "all" || item.dataset.book === bookValue;
                    const matchesArtist =
                        artistValue === "all" ||
                        item.dataset.artist === artistValue;

                    return matchesBook && matchesArtist;
                });

            const getBookLabel = (value) => {
                const button = document.querySelector(
                    `[data-book-filter="${value}"]`,
                );
                const text = button?.querySelector("span");
                return text?.textContent?.trim() ?? "Tous les romans";
            };

            const getArtistLabel = (value) => {
                const button = document.querySelector(
                    `[data-artist-filter="${value}"]`,
                );
                const text = button?.querySelector("span");
                return text?.textContent?.trim() ?? "Tous les artistes";
            };

            const updateButtonState = (buttons, activeValue, attr, counts) => {
                buttons.forEach((button) => {
                    const value = button.getAttribute(attr);
                    const count = value ? (counts.get(value) ?? 0) : 0;
                    const isActive = value === activeValue;
                    const isAvailable = isActive || count > 0;
                    const countEl = button.querySelector("[data-filter-count]");

                    button.dataset.active = String(isActive);
                    button.dataset.available = String(isAvailable);
                    button.disabled = !isAvailable;
                    button.setAttribute("aria-disabled", String(!isAvailable));

                    if (countEl) {
                        countEl.textContent = String(count);
                    }
                });
            };

            const updateSummary = (visibleCount) => {
                if (!resultSummary) {
                    return;
                }

                const parts = [
                    `${visibleCount} visuel${visibleCount > 1 ? "s" : ""}`,
                ];

                if (state.book !== "all") {
                    parts.push(getBookLabel(state.book));
                }

                if (state.artist !== "all") {
                    parts.push(getArtistLabel(state.artist));
                }

                resultSummary.textContent = parts.join(" • ");
            };

            const applyFilters = () => {
                const visibleItems = getItemMatches(state.book, state.artist);
                const visibleSet = new Set(visibleItems);
                const bookCounts = new Map();
                const artistCounts = new Map();

                bookButtons.forEach((button) => {
                    const value =
                        button.getAttribute("data-book-filter") ?? "all";
                    bookCounts.set(
                        value,
                        getItemMatches(value, state.artist).length,
                    );
                });

                artistButtons.forEach((button) => {
                    const value =
                        button.getAttribute("data-artist-filter") ?? "all";
                    artistCounts.set(
                        value,
                        getItemMatches(state.book, value).length,
                    );
                });

                itemEls.forEach((item) => {
                    const visible = visibleSet.has(item);

                    item.style.display = visible ? "block" : "none";
                });

                updateButtonState(
                    bookButtons,
                    state.book,
                    "data-book-filter",
                    bookCounts,
                );
                updateButtonState(
                    artistButtons,
                    state.artist,
                    "data-artist-filter",
                    artistCounts,
                );
                updateSummary(visibleItems.length);

                if (resetButton instanceof HTMLButtonElement) {
                    const hasCustomFilters =
                        state.book !== "all" || state.artist !== "all";
                    resetButton.disabled = !hasCustomFilters;
                }
            };

            const openModal = (trigger) => {
                if (
                    !modal ||
                    !modalImage ||
                    !modalTitle ||
                    !modalArtist ||
                    !modalDescription ||
                    !modalBook ||
                    !modalArtistDetail ||
                    !modalDate ||
                    !modalAlt ||
                    !modalLink
                ) {
                    return;
                }

                lastTrigger = trigger;

                modalImage.setAttribute("src", trigger.dataset.image ?? "");
                modalImage.setAttribute("alt", trigger.dataset.alt ?? "");
                modalTitle.textContent = trigger.dataset.title ?? "";
                modalArtist.textContent = trigger.dataset.artistLabel ?? "";
                modalDescription.textContent =
                    trigger.dataset.description ?? "";
                modalBook.textContent = trigger.dataset.bookLabel ?? "";
                modalArtistDetail.textContent =
                    trigger.dataset.artistLabel ?? "";
                modalDate.textContent = trigger.dataset.date ?? "";
                modalAlt.textContent = trigger.dataset.alt ?? "";
                const bookHref = trigger.dataset.bookHref ?? "";
                modalLink.setAttribute("href", bookHref || "#");
                modalLink.toggleAttribute("hidden", !bookHref);

                modal.classList.remove("pointer-events-none", "opacity-0");
                modal.classList.add("opacity-100");
                modal.setAttribute("aria-hidden", "false");
                document.body.style.overflow = "hidden";
                if (modalCloseButton instanceof HTMLButtonElement) {
                    modalCloseButton.focus();
                }
            };

            const closeModal = () => {
                if (!modal) {
                    return;
                }

                modal.classList.add("pointer-events-none", "opacity-0");
                modal.classList.remove("opacity-100");
                modal.setAttribute("aria-hidden", "true");
                document.body.style.overflow = "";

                if (lastTrigger instanceof HTMLElement) {
                    lastTrigger.focus();
                }
            };

            bookButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    if (button.disabled) {
                        return;
                    }

                    state.book =
                        button.getAttribute("data-book-filter") ?? "all";
                    applyFilters();
                });
            });

            artistButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    if (button.disabled) {
                        return;
                    }

                    state.artist =
                        button.getAttribute("data-artist-filter") ?? "all";
                    applyFilters();
                });
            });

            if (resetButton instanceof HTMLButtonElement) {
                resetButton.addEventListener("click", () => {
                    state.book = "all";
                    state.artist = "all";
                    applyFilters();
                });
            }

            itemEls.forEach((item) => {
                item.addEventListener("click", () => openModal(item));
            });

            if (modalCloseButton instanceof HTMLButtonElement) {
                modalCloseButton.addEventListener("click", closeModal);
            }

            modalCloseButtons.forEach((button) => {
                button.addEventListener("click", closeModal);
            });

            document.addEventListener("keydown", (event) => {
                if (
                    event.key === "Escape" &&
                    modal?.getAttribute("aria-hidden") === "false"
                ) {
                    closeModal();
                }
            });

            applyFilters();
        </script>

        <style>
            .gallery-filter[data-filter-kind="book"][data-active="true"] {
                background: #3a4d45;
