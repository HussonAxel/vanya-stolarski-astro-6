const getServiceGalleryCardWidth = (src: string) => {
  const dimensions = serviceImageDimensions[src];

  if (!dimensions) {
    return "width:min(72vw, 24rem);";
  }

  const ratio = dimensions.width / dimensions.height;

  if (ratio >= 1.75) {
    return "width:min(90vw, 42rem);";
  }

  if (ratio >= 1.2) {
    return "width:min(82vw, 34rem);";
  }

  if (ratio >= 0.9) {
    return "width:min(72vw, 28rem);";
  }

  if (ratio >= 0.55) {
    return "width:min(58vw, 22rem);";
  }

  return "width:min(52vw, 18rem);";
};
---

<Layout title="Tarifs - Vanya Stolarski">
  <main class="overflow-hidden bg-[#FFFAFA] text-[#3d3834]">
    <!-- ─── HERO ─── -->
    <section
      class="relative overflow-hidden bg-[#3d3834] px-6 py-24 text-[#FFFAFA]"
    >
      <div class="site-shell relative mt-20">
        <div
          class="mt-10 grid gap-10 md:grid-cols-[1.12fr_0.88fr] md:items-end"
        >
          <div class="space-y-6">
            <span
              class="inline-flex rounded-full border border-[#FFFAFA]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
            >
              Tarifs
            </span>
            <h1 class="max-w-5xl font-serif text-5xl leading-none text-balance md:text-7xl">
              J'habille les univers de livre comme j'approche mes romans, par regard, matiere et presence.
            </h1>
            <p
              class="max-w-2xl font-sans text-base leading-relaxed text-[#FFFAFA] md:text-lg"
            >
              {tariffsIntro}
            </p>

            <div class="flex flex-wrap gap-3 pt-2">
              <a
                href="#services"
                class="inline-flex items-center gap-3 rounded-full bg-[#3a4d45] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#FFFAFA] uppercase transition-all duration-300 hover:bg-[#FFFAFA] hover:text-[#3d3834]"
              >
                Voir les tarifs
              </a>
              <a
                href={contact.shopUrl}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-3 rounded-full border border-[#FFFAFA]/12 bg-transparent px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#FFFAFA] uppercase transition-all duration-300 hover:border-[#FFFAFA] hover:bg-[#FFFAFA] hover:text-[#3d3834]"
              >
                Boutique SumUp
              </a>
              <a
                href={`mailto:${contact.email}`}
                class="inline-flex items-center gap-3 rounded-full border border-[#FFFAFA]/12 bg-[#FFFAFA] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#3d3834] uppercase transition-all duration-300 hover:border-[#3a4d45]/40 hover:bg-[#FFFAFA]"
              >
                Demander un devis
              </a>
            </div>
          </div>

          <div
            class="section-panel fade-up rounded-lg border border-[#FFFAFA]/10 bg-[#FFFAFA] p-8 backdrop-blur-sm"
          >
            <div
              class="grid gap-6 sm:grid-cols-3 md:grid-cols-1 xl:grid-cols-3"
            >
              <div>
                <p class="font-serif text-5xl text-[#3a4d45]">7</p>
                <p
                  class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                >
                  Services
                </p>
              </div>
              <div>
                <p class="font-serif text-5xl text-[#3a4d45]">
                  {genresSnapshot.value}
                </p>
                <p
                  class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                >
                  {genresSnapshot.label}
                </p>
              </div>
              <div>
                <p class="font-serif text-5xl text-[#3a4d45]">Devis</p>
                <p
                  class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                >
                  Sur mesure
                </p>
              </div>
            </div>

            <div
              class="mt-8 rounded-[1.6rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-6"
            >
              <p
                class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#3a4d45] uppercase"
              >
                Contact
              </p>
              <div
                class="mt-4 space-y-3 font-sans text-sm leading-relaxed text-[#3d3834]"
              >
                <p>
                  Mail&nbsp;: <a
                    href={`mailto:${contact.email}`}
                    class="text-[#3d3834] underline underline-offset-4"
                    >{contact.email}</a
                  >
                </p>
                <p>
                  Instagram&nbsp;: <a
                    href={contact.instagramUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="text-[#3d3834] underline underline-offset-4"
                    >{contact.instagramHandle}</a
                  >
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SERVICES ─── -->
    <section
      id="services"
      class="relative overflow-hidden bg-[#FFFAFA] px-6 py-24"
    >
      <div class="site-shell relative space-y-6">
        <div class="max-w-3xl space-y-4">
          <p
            class="font-sans text-[10px] font-bold tracking-[0.35em] text-[#3a4d45] uppercase"
          >
            Services
          </p>
          <h2 class="font-serif text-4xl leading-none text-balance md:text-6xl">
            Des prestations pensées pour donner plus de matière, plus de
            finition et plus de désir à l'objet livre.
          </h2>
          <p
            class="max-w-2xl font-sans text-base leading-relaxed text-[#3d3834]/78 md:text-lg"
          >
            Pour toute demande personnalisée ou pour un devis, n'hésite pas à me
            contacter par mail ou via Instagram. Les tarifs affichés ici servent
            de repère selon le type de prestation.
          </p>
        </div>

        <div class="space-y-10 pt-8 lg:space-y-12">
          {
            services.map((service) => (
              <section class="section-panel fade-up space-y-7 overflow-hidden rounded-[2.4rem] bg-[#fffdfa] p-6 md:p-8 xl:p-10">
                {/* ── En-tête service ── */}
                <div class="flex flex-wrap items-start justify-between gap-5 border-b border-[#3d3834]/8 pb-6">
                  <div class="space-y-2.5">
                    <p class="font-sans text-[10px] font-bold tracking-[0.34em] text-[#3a4d45] uppercase">
                      {service.eyebrow}
                    </p>
                    <h3 class="font-serif text-3xl leading-[0.95] text-[#3d3834] text-balance md:text-[2.6rem]">
                      {service.name}
                    </h3>
                  </div>
                  <div class="flex items-center gap-3 pt-1">
                    <span
                      class="whitespace-nowrap rounded-full px-5 py-2.5 font-sans text-[11px] font-extrabold tracking-[0.16em] uppercase shadow-[0_10px_24px_rgba(61,56,52,0.18)] ring-1 ring-[#FFFAFA]/18 md:text-xs"
                      style={`background:${service.accent}; color:#FFFAFA;`}
                    >
                      {service.price}
                    </span>
                    <a
                      href={`mailto:${contact.email}`}
                      class="inline-flex w-full items-center gap-2 rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.2em] text-[#3d3834] uppercase transition-all duration-300 hover:border-[#3a4d45]/35 hover:bg-[#3a4d45] hover:text-[#FFFAFA]"
                    >
                      Demander un devis
                    </a>
                  </div>
                </div>

                {/* ── Galerie ── */}
                <div class="service-gallery space-y-4" data-service-gallery-root>
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                      <span class="inline-flex rounded-full border border-[#3d3834]/8 bg-[#fffaf8] px-3 py-1.5 font-sans text-[9px] font-bold tracking-[0.18em] text-[#3d3834]/66 uppercase">
                        {service.gallery.length} visuels
                      </span>
                    </div>
                    <span class="inline-flex items-center gap-2 rounded-full border border-[#3d3834]/8 bg-[#fffaf8] px-3 py-1.5 font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/62 uppercase">
                      <span aria-hidden="true" class="text-sm leading-none text-[#3a4d45]">←</span>
                      Faire défiler
                      <span aria-hidden="true" class="text-sm leading-none text-[#3a4d45]">→</span>
                    </span>
                  </div>

                  <div class="relative">
                    <div
                      data-service-gallery-scroller
                      class="-mx-2 flex cursor-grab gap-5 overflow-x-auto px-2 pb-4 snap-x snap-mandatory [scrollbar-width:auto] [scrollbar-color:rgba(58,77,69,0.55)_rgba(61,56,52,0.10)] active:cursor-grabbing"
                    >
                      {service.gallery.map((img, i) => (
                        <figure
                          class="group relative shrink-0 snap-start"
                          style={getServiceGalleryCardWidth(img.src)}
                        >
                          <button
                            type="button"
                            class="service-gallery-trigger block w-full text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#3a4d45] focus-visible:ring-offset-4 focus-visible:ring-offset-[#fffdfa]"
                            data-service-gallery-trigger
                            data-image={img.src}
                            data-alt={img.alt}
                            data-title={img.label}
                            data-service={service.name}
                            data-eyebrow={service.eyebrow}
                            data-price={service.price}
                            data-description={service.description}
                            data-format={service.format}
                            data-universe={service.universe}
                            data-focus={service.focus}
                            data-width={serviceImageDimensions[img.src]?.width}
                            data-height={serviceImageDimensions[img.src]?.height}
                            aria-label={`Voir ${img.label} en grand`}
                          >
                            <div
                              class="relative flex h-[18rem] items-center justify-center overflow-hidden rounded-[1.9rem] border border-[#3d3834]/8 bg-[linear-gradient(180deg,#fffdfa_0%,#f2e9e4_100%)] p-3 transition-all duration-500 sm:h-[21rem] sm:p-4 md:h-[24rem] lg:h-[27rem]"
                            >
                              <img
                                src={img.src}
                                alt={img.alt}
                                width={serviceImageDimensions[img.src]?.width}
                                height={serviceImageDimensions[img.src]?.height}
                                class="h-full w-full rounded-[0.8rem] object-contain transition-transform duration-500 group-hover:scale-[1.02]"
                                loading={i === 0 ? "eager" : "lazy"}
                              />
                              <span class="absolute bottom-4 left-4 inline-flex rounded-full border border-[#FFFAFA]/20 bg-[#3d3834]/78 px-3 py-1.5 font-sans text-[9px] font-bold tracking-[0.22em] text-[#FFFAFA] uppercase backdrop-blur-sm">
                                {img.label}
                              </span>
                            </div>
                          </button>
                        </figure>
                      ))}
                    </div>

                    <div class="pointer-events-none mt-2 flex items-center gap-3 px-2 md:hidden">
                      <span class="font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/48 uppercase">
                        Glisser
                      </span>
                      <div class="relative h-px flex-1 overflow-hidden rounded-full bg-[#3d3834]/10">
                        <span class="absolute inset-y-0 left-0 w-16 rounded-full bg-[#3a4d45]/28"></span>
                      </div>
                      <span aria-hidden="true" class="font-serif text-lg leading-none text-[#3a4d45]/72">→</span>
                    </div>


                  </div>
                </div>

                {/* ── Infos compactes ── */}
                <div class="grid gap-6 border-t border-[#3d3834]/8 pt-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)] lg:items-start lg:gap-8">
                  <div class="space-y-4">
                    <p class="max-w-2xl font-sans text-[0.98rem] leading-8 text-[#3d3834]/72">
                      {service.description}
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {service.tags.map((tag) => (
                        <span class="rounded-full border border-[#3d3834]/8 bg-[#fffaf8] px-3 py-1 font-sans text-[9px] font-bold tracking-[0.16em] text-[#3d3834]/70 uppercase">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                  <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
                    <div class="rounded-[1.7rem] border border-[#3d3834]/8 bg-[#fffaf8] px-4 py-4">
                      <p class="font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/50 uppercase">
                        Format
                      </p>
                      <p class="mt-2 font-serif text-[1.35rem] leading-tight text-[#3d3834]">
                        {service.format}
                      </p>
                    </div>
                    <div class="rounded-[1.7rem] border border-[#3d3834]/8 bg-[#fffaf8] px-4 py-4">
                      <p class="font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/50 uppercase">
                        Adapté à
                      </p>
                      <p class="mt-2 font-serif text-[1.35rem] leading-tight text-[#3d3834]">
                        {service.universe}
                      </p>
                    </div>
                    <div class="rounded-[1.7rem] border border-[#3d3834]/8 bg-[#fffaf8] px-4 py-4">
                      <p class="font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/50 uppercase">
                        Focus
                      </p>
                      <p class="mt-2 font-serif text-[1.35rem] leading-tight text-[#3d3834]">
                        {service.focus}
                      </p>
                    </div>
                  </div>
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </section>

    <div
      id="service-gallery-modal"
      class="pointer-events-none fixed inset-0 z-[80] flex items-start justify-center overflow-y-auto bg-[#3d3834]/74 px-4 py-4 opacity-0 transition-all duration-300 md:items-center md:py-8"
      role="dialog"
      aria-modal="true"
      aria-labelledby="service-gallery-modal-title"
      aria-hidden="true"
    >
      <div data-service-gallery-close class="absolute inset-0"></div>
      <div class="relative z-10 my-auto w-full max-w-[min(96vw,1380px)] overflow-hidden rounded-[2.2rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] shadow-[0_35px_120px_-50px_rgba(61,56,52,0.6)] lg:max-h-[92vh]">
        <button
          type="button"
          id="service-gallery-modal-close"
          class="absolute top-4 right-4 z-20 inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#3d3834]/10 bg-[#FFFAFA]/92 font-sans text-xs font-bold tracking-[0.2em] text-[#3d3834] uppercase shadow-[0_10px_30px_-24px_rgba(61,56,52,0.55)] transition-all duration-300 hover:border-[#3a4d45]/30 hover:bg-[#3a4d45] hover:text-[#FFFAFA]"
          aria-label="Fermer la popup"
        >
          X
        </button>

        <div class="grid lg:grid-cols-[minmax(0,1fr)_390px] lg:items-stretch">
          <div class="relative flex min-h-[40vh] items-center justify-center overflow-hidden bg-[#3d3834] px-4 py-16 md:min-h-[54vh] md:px-6 lg:min-h-0 lg:px-8 lg:py-8">
            <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,250,248,0.08),transparent_56%)]"></div>
            <div class="relative flex w-full items-center justify-center">
              <button
                type="button"
                id="service-gallery-modal-prev"
                class="absolute left-0 top-1/2 z-10 inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#FFFAFA]/14 bg-[#FFFAFA]/10 font-sans text-lg text-[#FFFAFA] backdrop-blur-sm transition-all duration-300 hover:bg-[#FFFAFA] hover:text-[#3d3834] disabled:pointer-events-none disabled:opacity-30"
                aria-label="Image précédente"
