---
import LatestUluleCampaign from "./LatestUluleCampaign.astro";

const currentPath = Astro.url.pathname;

const navLinks = [
  {
    label: "Livres",
    subtitle: "Collection",
    icon: "book",
    href: "/livres",
  },
  {
    label: "Boutique",
    subtitle: "SumUp",
    icon: "bag",
    href: "https://vanyastolarski.sumupstore.com/",
    external: true,
  },
  {
    label: "Citations",
    subtitle: "Extraits",
    icon: "quote",
    href: "/citations",
  },
  {
    label: "Avis",
    subtitle: "Lectrices",
    icon: "sparkles",
    href: "/reviews",
  },
  {
    label: "Galeries",
    subtitle: "Atelier",
    icon: "image",
    href: "/galerie",
  },
];

const socialPlatforms = [
  {
    label: "TikTok",
    icon: "tiktok",
    href: "https://www.tiktok.com/@vanyastolar.auteure",
  },
  {
    label: "Instagram",
    icon: "instagram",
    href: "https://www.instagram.com/vanyastolar.auteure/",
  },
  {
    label: "Ulule",
    icon: "ulule",
    href: "https://fr.ulule.com/users/vanya-stolarski/#/projects/online/",
  },
];

const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<section
  class="relative flex min-h-screen items-center bg-[#1c1917] pt-28 pb-8 md:h-[100svh] md:min-h-0 md:items-stretch md:pt-28 md:pb-8 lg:pt-32 lg:pb-10"
  data-menu-close
>
  <div class="site-shell relative z-10 w-full">
    <div
      class="grid auto-rows-min grid-cols-1 gap-4 md:h-[calc(100svh-8.5rem)] md:auto-rows-fr md:grid-cols-12 md:items-stretch lg:gap-5"
    >
      <!-- LEFT PANEL — Navigation -->
      <div
        class="hero-card group/hero-left relative flex min-h-[560px] flex-col justify-between overflow-hidden rounded-3xl bg-[#faf8f6] p-7 md:col-span-4 md:h-full md:min-h-0 md:p-8 lg:rounded-[2rem] lg:p-9"
      >
        <div class="relative z-10 flex h-full flex-col">
          <div class="flex h-full flex-col">
            <div class="space-y-7 lg:space-y-9">
              <div class="space-y-3">
                <div class="flex items-center gap-2.5">
                  <div class="h-px w-7 bg-[#1c1917]/25"></div>
                  <span
                    class="font-sans text-[10px] font-semibold tracking-[0.35em] text-[#1c1917]/50 uppercase"
                  >
                    Autrice & Illustratrice
                  </span>
                </div>
                <h1
                  class="font-serif text-5xl leading-none tracking-tight text-[#1c1917] lg:text-6xl"
                >
                  Explorer
                </h1>
              </div>

              <nav class="hero-nav space-y-2">
                {
                  navLinks.map((link) => {
                    const active = link.external ? false : isActive(link.href);

                    return (
                      <a
                        href={link.href}
                        target={link.external ? "_blank" : undefined}
                        rel={link.external ? "noreferrer" : undefined}
                        data-active={active ? "true" : "false"}
                        class:list={[
                          "hero-nav-link group relative flex w-full items-center justify-between rounded-2xl border p-3 transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1c1917]/20 focus-visible:ring-offset-2",
                          active
                            ? "border-[#1c1917] bg-[#1c1917] text-white shadow-lg shadow-[#1c1917]/15"
                            : "border-[#1c1917]/10 bg-transparent text-[#1c1917] hover:border-[#3a4d45] hover:bg-[#3a4d45] hover:text-white hover:shadow-lg hover:shadow-[#3a4d45]/20",
                        ]}
                      >
                        <div class="flex items-center gap-3.5">
                          <div
                            class:list={[
                              "flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300",
                              active
                                ? "bg-white/15 text-white"
                                : "bg-[#1c1917]/[0.06] text-[#1c1917]/70 group-hover:bg-white/15 group-hover:text-white",
                            ]}
                          >
                            {link.icon === "book" && (
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="19"
                                height="19"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.75"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
                              </svg>
                            )}
                            {link.icon === "bag" && (
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="19"
                                height="19"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.75"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <path d="M6 8h12l-1 11a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2z" />
                                <path d="M9 8V6a3 3 0 0 1 6 0v2" />
                                <path d="M10 12a2 2 0 1 0 4 0" />
                              </svg>
                            )}
                            {link.icon === "image" && (
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="19"
                                height="19"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.75"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <rect
                                  width="18"
                                  height="18"
                                  x="3"
                                  y="3"
                                  rx="2"
                                  ry="2"
                                />
                                <circle cx="9" cy="9" r="2" />
                                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                              </svg>
                            )}
                            {link.icon === "quote" && (
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="19"
                                height="19"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.75"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z" />
                                <path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z" />
                              </svg>
                            )}
                            {link.icon === "sparkles" && (
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="19"
                                height="19"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.75"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" />
                              </svg>
                            )}
                          </div>
                          <div class="flex flex-col gap-0.5">
                            <span class="font-serif text-lg leading-none transition-colors duration-300">
                              {link.label}
                            </span>
                            <span
                              class:list={[
                                "font-sans text-[9px] font-medium tracking-widest uppercase transition-colors duration-300",
                                active
                                  ? "text-white/60"
                                  : "text-[#1c1917]/40 group-hover:text-white/60",
                              ]}
                            >
                              {link.subtitle}
                            </span>
                          </div>
                        </div>

                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="16"
                          height="16"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class:list={[
                            "transition-all duration-300",
                            active
                              ? "text-white/60"
                              : "text-[#1c1917]/25 group-hover:translate-x-0.5 group-hover:text-white/60",
                          ]}
                        >
                          <path d="m9 18 6-6-6-6" />
                        </svg>
                      </a>
                    );
                  })
                }
              </nav>
            </div>

            <div class="mt-auto border-t border-[#1c1917]/[0.06] pt-5">
              <div class="flex flex-wrap justify-center gap-2">
                {
                  socialPlatforms.map((platform) => (
                    <a
                      href={platform.href}
                      target="_blank"
                      rel="noreferrer"
                      aria-label={`Ouvrir ${platform.label}`}
                      class="hero-social-pill group/social inline-flex items-center gap-2 rounded-full bg-[#1c1917]/[0.04] px-4 py-2.5 text-[#1c1917]/70 transition-all duration-300 hover:bg-[#3a4d45] hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1c1917]/20 focus-visible:ring-offset-2"
                    >
                      <span class="flex h-5 w-5 items-center justify-center">
                        {platform.icon === "instagram" && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                          >
                            <rect x="3" y="3" width="18" height="18" rx="5" />
                            <circle cx="12" cy="12" r="4" />
                            <circle
                              cx="17.5"
                              cy="6.5"
                              r="1"
                              fill="currentColor"
                              stroke="none"
                            />
                          </svg>
                        )}
                        {platform.icon === "tiktok" && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                          >
                            <path d="M14 4c.5 1.9 1.8 3.6 4 4.2" />
                            <path d="M10 11.5V5h4v10.5a3.5 3.5 0 1 1-3.5-3.5" />
                          </svg>
                        )}
                        {platform.icon === "ulule" && (
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                          >
                            <path d="M7 7v6a5 5 0 0 0 10 0V7" />
                            <path d="M7 17h10" />
                          </svg>
                        )}
                      </span>
                      <span class="font-sans text-[9px] font-semibold tracking-[0.2em] uppercase">
                        {platform.label}
                      </span>
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT PANELS -->
      <div
        class="relative z-10 grid grid-cols-1 gap-4 md:col-span-8 md:h-full md:min-h-0 md:grid-cols-2 md:grid-rows-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-5"
      >
        <!-- Services card -->
        <div
          class="hero-card group relative flex min-h-[300px] flex-col justify-between overflow-hidden rounded-3xl bg-[#292524] p-7 md:h-full md:min-h-0 md:p-8 lg:rounded-[2rem] lg:p-9"
        >
          <div class="relative z-10 space-y-5">
            <div class="flex items-center justify-between">
              <div
                class="flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 transition-colors duration-300 group-hover:bg-white/15"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-white/80"
                >
                  <path
                    d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"
                  ></path>
                </svg>
              </div>
              <span
                class="rounded-full bg-white/10 px-3 py-1.5 font-sans text-[9px] font-semibold tracking-[0.2em] text-white/70 uppercase"
              >
                Prestations
              </span>
            </div>

            <div class="space-y-2">
              <h3 class="font-serif text-4xl leading-none text-white">
                Services
              </h3>
              <p class="font-sans text-sm leading-relaxed text-white/50">
                Accompagnement créatif et direction artistique.
              </p>
            </div>

            <div class="flex flex-wrap gap-2">
              <a
                href="/galerie"
                class="inline-flex h-10 items-center rounded-xl bg-white px-5 font-sans text-[10px] font-semibold tracking-widest text-[#1c1917] uppercase transition-all duration-300 hover:bg-white/90"
              >
                Galerie
              </a>
              <a
                href="/tarifs"
                class="inline-flex h-10 items-center rounded-xl bg-white/10 px-5 font-sans text-[10px] font-semibold tracking-widest text-white uppercase transition-all duration-300 hover:bg-white/[0.16]"
              >
                Portfolio
              </a>
            </div>
          </div>
        </div>

        <!-- YouTube card -->
        <div
          class="hero-card group relative flex min-h-[300px] flex-col justify-between overflow-hidden rounded-3xl bg-[#faf8f6] p-7 md:h-full md:min-h-0 md:p-8 lg:rounded-[2rem] lg:p-9"
        >
          <div class="relative z-10 space-y-5">
            <div class="flex items-center justify-between">
              <div
                class="flex h-11 w-11 items-center justify-center rounded-xl bg-[#1c1917]/[0.06] text-[#1c1917]/70"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"
                  ></path>
                  <path d="m10 15 5-3-5-3z"></path>
                </svg>
              </div>
              <span
                class="rounded-full bg-[#1c1917]/[0.06] px-3 py-1.5 font-sans text-[9px] font-semibold tracking-[0.2em] text-[#1c1917]/50 uppercase"
              >
                Playlists
              </span>
            </div>

            <h3 class="font-serif text-4xl leading-none text-[#1c1917]">
              YouTube
            </h3>

            <div class="space-y-2">
              <a
                href="https://www.youtube.com/watch?v=ReucEI_1ON4&list=PLVXimxL_FsmRbztlkOcut0Nn8ILUXwzRT"
                class="group/link flex items-center justify-between rounded-xl bg-[#1c1917]/[0.03] p-3.5 transition-all duration-300 hover:bg-[#1c1917] hover:text-white"
              >
                <span
                  class="flex items-center gap-2.5 font-sans text-xs text-[#1c1917]/70 transition-colors duration-300 group-hover/link:text-white"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="11"
                    height="11"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    stroke="none"
                    class="opacity-40 transition-opacity duration-300 group-hover/link:opacity-70"
                  >
                    <path
                      d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"
                    ></path>
                  </svg>
                  Playlist - Coeur De Renard
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-[#1c1917]/20 transition-all duration-300 group-hover/link:translate-x-0.5 group-hover/link:text-white/60"
                >
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </a>
              <a
                href="https://www.youtube.com/watch?v=QmrU94FzTSI&list=PLVXimxL_FsmQJipEaN7eBoVW4l9XBOJqF"
                class="group/link flex items-center justify-between rounded-xl bg-[#1c1917]/[0.03] p-3.5 transition-all duration-300 hover:bg-[#1c1917] hover:text-white"
              >
                <span
                  class="flex items-center gap-2.5 font-sans text-xs text-[#1c1917]/70 transition-colors duration-300 group-hover/link:text-white"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="11"
                    height="11"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    stroke="none"
                    class="opacity-40 transition-opacity duration-300 group-hover/link:opacity-70"
                  >
                    <path
                      d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"
                    ></path>
                  </svg>
                  Playlist - Fous-Papillons
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-[#1c1917]/20 transition-all duration-300 group-hover/link:translate-x-0.5 group-hover/link:text-white/60"
                >
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </a>
              <a
                href="https://www.youtube.com/watch?v=wPY6dOC-MDA&list=PLVXimxL_FsmSAfAhgqJiFWwFJvtPO8MsY"
                class="group/link flex items-center justify-between rounded-xl bg-[#1c1917]/[0.03] p-3.5 transition-all duration-300 hover:bg-[#1c1917] hover:text-white"
              >
                <span
                  class="flex items-center gap-2.5 font-sans text-xs text-[#1c1917]/70 transition-colors duration-300 group-hover/link:text-white"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="11"
                    height="11"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    stroke="none"
                    class="opacity-40 transition-opacity duration-300 group-hover/link:opacity-70"
                  >
                    <path
                      d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"
                    ></path>
                  </svg>
                  Playlist - Notre sang dans l'humus de la foret
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-[#1c1917]/20 transition-all duration-300 group-hover/link:translate-x-0.5 group-hover/link:text-white/60"
                >
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </a>
              <a
                href="https://www.youtube.com/watch?v=MMnuiwCHbdc&list=PLVXimxL_FsmRbtkliOQgQDU0FZkXAKxwV"
                class="group/link flex items-center justify-between rounded-xl bg-[#1c1917]/[0.03] p-3.5 transition-all duration-300 hover:bg-[#1c1917] hover:text-white"
              >
                <span
                  class="flex items-center gap-2.5 font-sans text-xs text-[#1c1917]/70 transition-colors duration-300 group-hover/link:text-white"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="11"
                    height="11"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    stroke="none"
                    class="opacity-40 transition-opacity duration-300 group-hover/link:opacity-70"
                  >
                    <path
                      d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"
                    ></path>
                  </svg>
                  Playlist - Trouver la Lune
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-[#1c1917]/20 transition-all duration-300 group-hover/link:translate-x-0.5 group-hover/link:text-white/60"
                >
                  <path d="m9 18 6-6-6-6"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Ulule campaign -->
        <div class="md:col-span-2 md:h-full md:min-h-0">
          <LatestUluleCampaign server:defer>
            <div
              slot="fallback"
              class="hero-card group relative h-full min-h-[22rem] overflow-hidden rounded-3xl bg-[#292524] p-7 md:min-h-0 md:p-8 lg:rounded-[2rem] lg:p-9"
            >
              <div
                class="relative z-10 grid h-full gap-7 lg:grid-cols-[minmax(0,1fr)_minmax(240px,300px)] lg:items-end"
              >
                <div class="space-y-5">
                  <div class="space-y-4">
                    <span
                      class="inline-flex rounded-full bg-white/10 px-4 py-2 font-sans text-[10px] font-semibold tracking-[0.25em] text-white/70 uppercase"
                    >
                      Dernière campagne Ulule
                    </span>
