        label: "Double page",
      },
      {
        src: "/assets/services/pagedegarde/pdg3.webp",
        alt: "Exemple de pages de garde illustrées 3",
        label: "Univers",
      },
    ],
    tags: ["Intérieur", "Sur devis", "Univers sur mesure"],
    description:
      "Des pages de garde pour poser un décor, prolonger un imaginaire et donner plus de profondeur au livre dès la première ouverture.",
  },
  {
    name: "Entêtes de chapitres",
    eyebrow: "Finition intérieure",
    price: "À partir de 20 €",
    accent: "#3a4d45",
    format: "Chapitrage",
    universe: "Fantasy & SF",
    focus: "Rythme de lecture",
    gallery: [
      {
        src: "/assets/services/headers/header-one.webp",
        alt: "Exemple d'entête de chapitre 1",
        label: "Minimal",
      },
      {
        src: "/assets/services/headers/header-three.webp",
        alt: "Exemple d'entête de chapitre 2",
        label: "Orné",
      },
      {
        src: "/assets/services/headers/header-seven.webp",
        alt: "Exemple d'entête de chapitre 3",
        label: "Saga",
      },
      {
        src: "/assets/services/headers/header-ten.webp",
        alt: "Exemple d'entête de chapitre 4",
        label: "Prestige",
      },
    ],
    tags: ["Chapitrage", "À partir de 20 €", "Personnalisable"],
    description:
      "Des entêtes de chapitres pour donner au texte une finition plus élégante et renforcer la cohérence visuelle de l'ensemble.",
  },
  {
    name: "Cartographie",
    eyebrow: "Monde & territoire",
    price: "200 € / 400 €",
    accent: "#3a4d45",
    format: "1 ou 2 pages",
    universe: "Mondes imaginaires",
    focus: "Lecture immersive",
    gallery: [
      {
        src: "/assets/services/maps/maps-one.webp",
        alt: "Exemple de carte fantasy 1",
        label: "Royaume",
      },
      {
        src: "/assets/services/maps/maps-four.webp",
        alt: "Exemple de carte fantasy 2",
        label: "Archipel",
      },
      {
        src: "/assets/services/maps/maps-six.webp",
        alt: "Exemple de carte fantasy 3",
        label: "Relief",
      },
      {
        src: "/assets/services/maps/maps-seven.webp",
        alt: "Exemple de carte fantasy 4",
        label: "Double page",
      },
    ],
    tags: ["1 page", "2 pages", "Mondes imaginaires"],
    description:
      "Des cartes détaillées pour ancrer les lieux, clarifier les trajets et renforcer la sensation d'univers complet autour du roman.",
  },
  {
    name: "Illustration",
    eyebrow: "Direction visuelle",
    price: "Sous devis",
    accent: "#3d3834",
    format: "Illustration sur mesure",
    universe: "Fantasy & SF",
    focus: "Campagne & contenu",
    gallery: [
      {
        src: "/assets/services/illustrations/illustration-one.webp",
        alt: "Exemple d'illustration fantasy 1",
        label: "Portrait",
      },
      {
        src: "/assets/services/illustrations/illustration-seven.webp",
        alt: "Exemple d'illustration fantasy 2",
        label: "Scène",
      },
      {
        src: "/assets/services/illustrations/illustration-eleven.webp",
        alt: "Exemple d'illustration fantasy 3",
        label: "Ambiance",
      },
      {
        src: "/assets/services/illustrations/illustration-fifteen.webp",
        alt: "Exemple d'illustration fantasy 4",
        label: "Campagne",
      },
    ],
    tags: ["Illustration", "Fantasy", "Sous devis"],
    description:
      "Des illustrations pour prolonger l'univers du livre, nourrir la communication et donner des images fortes aux personnages ou aux scènes.",
  },
];

const commitments = [
  {
    title: "Univers ciblés",
    text: "Je travaille avant tout autour de la fantasy et de la science-fiction, avec une recherche de rendu plus luxueux, plus singulier et plus éditorial.",
  },
  {
    title: "Formats variables",
    text: "Les prestations peuvent s'adapter à plusieurs tailles, niveaux de finition et contraintes de fabrication selon le projet et le support final.",
  },
  {
    title: "Demande sur mesure",
    text: "Pour toute demande personnalisée ou pour un devis, tu peux me contacter directement par mail ou via Instagram afin que l'on cadre le besoin ensemble.",
  },
];

const process = [
  {
    step: "01",
    title: "Prise de contact",
    text: "On échange sur le livre, l'univers, les références visuelles et le type de rendu attendu.",
  },
  {
    step: "02",
    title: "Devis et cadrage",
    text: "Je précise le format, la personnalisation possible, les livrables et le tarif selon la demande.",
  },
  {
    step: "03",
    title: "Production",
    text: "Je réalise le visuel ou l'élément éditorial en gardant la cohérence du projet et la qualité d'exécution.",
  },
];
---

<Layout title="Tarifs - Vanya Stolarski">
  <main class="overflow-hidden bg-[#FFFAFA] text-[#3d3834]">
    <!-- ─── HERO ─── -->
    <section
      class="relative overflow-hidden bg-[#3d3834] px-6 py-24 text-[#FFFAFA]"
    >
      <div class="site-shell relative mt-20">
        <div
          class="mt-10 grid gap-10 md:grid-cols-[1.12fr_0.88fr] md:items-end"
        >
          <div class="space-y-6">
            <span
              class="inline-flex rounded-full border border-[#FFFAFA]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
            >
              Tarifs
            </span>
            <h1 class="max-w-5xl font-serif text-5xl leading-none md:text-7xl">
              Voici les tarifs de mes services pour enrichir, habiller et donner
              plus de présence à un univers de livre.
            </h1>
            <p
              class="max-w-2xl font-sans text-base leading-relaxed text-[#FFFAFA] md:text-lg"
            >
              Je propose des visuels et éléments éditoriaux pour les romans de
              fantasy et de science-fiction, avec une recherche de luxe, de
              qualité et d'identité forte.
            </p>

            <div class="flex flex-wrap gap-3 pt-2">
              <a
                href="#services"
                class="inline-flex items-center gap-3 rounded-full bg-[#3a4d45] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#FFFAFA] uppercase transition-all duration-300 hover:-translate-y-1 hover:bg-[#FFFAFA] hover:text-[#3d3834]"
              >
                Voir les tarifs
              </a>
              <a
                href={`mailto:${contact.email}`}
                class="inline-flex items-center gap-3 rounded-full border border-[#FFFAFA]/12 bg-[#FFFAFA] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#3d3834] uppercase transition-all duration-300 hover:-translate-y-1 hover:border-[#3a4d45]/40 hover:bg-[#FFFAFA]"
              >
                Demander un devis
              </a>
            </div>
          </div>

          <div
            class="section-panel fade-up rounded-lg border border-[#FFFAFA]/10 bg-[#FFFAFA] p-8 backdrop-blur-sm"
          >
            <div
              class="grid gap-6 sm:grid-cols-3 md:grid-cols-1 xl:grid-cols-3"
            >
              <div>
                <p class="font-serif text-5xl text-[#3a4d45]">7</p>
                <p
                  class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                >
                  Services
                </p>
              </div>
              <div>
                <p class="font-serif text-5xl text-[#3a4d45]">SF</p>
                <p
                  class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                >
                  Fantasy & SF
                </p>
              </div>
              <div>
                <p class="font-serif text-5xl text-[#3a4d45]">Devis</p>
                <p
                  class="mt-2 font-sans text-[10px] font-bold tracking-[0.25em] text-[#3d3834] uppercase"
                >
                  Sur mesure
                </p>
              </div>
            </div>

            <div
              class="mt-8 rounded-[1.6rem] border border-[#FFFAFA]/10 bg-[#FFFAFA] p-6"
            >
              <p
                class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#3a4d45] uppercase"
              >
                Contact
              </p>
              <div
                class="mt-4 space-y-3 font-sans text-sm leading-relaxed text-[#3d3834]"
              >
                <p>
                  Mail&nbsp;: <a
                    href={`mailto:${contact.email}`}
                    class="text-[#3d3834] underline underline-offset-4"
                    >{contact.email}</a
                  >
                </p>
                <p>
                  Instagram&nbsp;: <a
                    href={contact.instagramUrl}
                    target="_blank"
                    rel="noreferrer"
                    class="text-[#3d3834] underline underline-offset-4"
                    >{contact.instagramHandle}</a
                  >
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SERVICES ─── -->
    <section
      id="services"
      class="relative overflow-hidden bg-[#FFFAFA] px-6 py-24"
    >
      <div class="site-shell relative space-y-6">
        <div class="max-w-3xl space-y-4">
          <p
            class="font-sans text-[10px] font-bold tracking-[0.35em] text-[#3a4d45] uppercase"
          >
            Services
          </p>
          <h2 class="font-serif text-4xl leading-none md:text-6xl">
            Des prestations pensées pour donner plus de matière, plus de
            finition et plus de désir à l'objet livre.
          </h2>
          <p
            class="max-w-2xl font-sans text-base leading-relaxed text-[#3d3834]/78 md:text-lg"
          >
            Pour toute demande personnalisée ou pour un devis, n'hésite pas à me
            contacter par mail ou via Instagram. Les tarifs affichés ici servent
            de repère selon le type de prestation.
          </p>
        </div>

        <div class="space-y-20 pt-8">
          {
            services.map((service) => (
              <section class="section-panel fade-up space-y-5">
                {/* ── En-tête service ── */}
                <div class="flex flex-wrap items-end justify-between gap-4 border-b border-[#3d3834]/8 pb-5">
                  <div class="space-y-1.5">
                    <p class="font-sans text-[10px] font-bold tracking-[0.34em] text-[#3a4d45] uppercase">
                      {service.eyebrow}
                    </p>
                    <h3 class="font-serif text-3xl leading-none text-[#3d3834] md:text-[2.6rem]">
                      {service.name}
                    </h3>
                  </div>
                  <div class="flex flex-wrap items-center gap-3">
                    <span
                      class="rounded-full px-4 py-2 font-sans text-[10px] font-bold tracking-[0.22em] uppercase"
                      style={`background:${service.accent}; color:#FFFAFA;`}
                    >
                      {service.price}
                    </span>
                    <a
                      href={`mailto:${contact.email}`}
                      class="inline-flex items-center gap-2 rounded-full border border-[#3d3834]/10 bg-[#FFFAFA] px-4 py-2 font-sans text-[10px] font-bold tracking-[0.2em] text-[#3d3834] uppercase transition-all duration-300 hover:-translate-y-0.5 hover:border-[#3a4d45]/35 hover:bg-[#3a4d45] hover:text-[#FFFAFA]"
                    >
                      Demander un devis
                    </a>
                  </div>
                </div>

                {/* ── Galerie horizontale ── */}
                <div class="service-gallery -mx-6 px-6">
                  <div class="flex gap-4 overflow-x-auto pb-4 scrollbar-thin">
                    {service.gallery.map((img, i) => (
                      <figure class="group relative flex-shrink-0">
                        <div class="overflow-hidden rounded-2xl border border-[#3d3834]/6 bg-[#f6efec] shadow-[0_12px_40px_-20px_rgba(61,56,52,0.2)] transition-shadow duration-300 group-hover:shadow-[0_16px_50px_-18px_rgba(61,56,52,0.32)]">
                          <img
                            src={img.src}
                            alt={img.alt}
                            class="aspect-[3/4] w-56 object-cover transition-transform duration-500 group-hover:scale-[1.02] sm:w-64 md:w-72 lg:w-80"
                            loading={i === 0 ? "eager" : "lazy"}
                          />
                        </div>
                        <figcaption class="mt-2.5 px-1 font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/55 uppercase">
                          {img.label}
                        </figcaption>
                      </figure>
                    ))}
                  </div>
                </div>

                {/* ── Infos compactes ── */}
                <div class="grid gap-4 sm:grid-cols-[1fr_auto] sm:items-start">
                  <div class="space-y-3">
                    <p class="max-w-xl font-sans text-[0.94rem] leading-relaxed text-[#3d3834]/72">
                      {service.description}
                    </p>
                    <div class="flex flex-wrap gap-2">
                      {service.tags.map((tag) => (
                        <span class="rounded-full border border-[#3d3834]/8 bg-[#fffaf8] px-3 py-1 font-sans text-[9px] font-bold tracking-[0.16em] text-[#3d3834]/70 uppercase">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                  <div class="flex flex-wrap gap-2.5 sm:flex-nowrap">
                    <div class="rounded-2xl border border-[#3d3834]/8 bg-[#fffaf8] px-4 py-3">
                      <p class="font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/50 uppercase">
                        Format
                      </p>
                      <p class="mt-1 font-serif text-lg leading-tight text-[#3d3834]">
                        {service.format}
                      </p>
                    </div>
                    <div class="rounded-2xl border border-[#3d3834]/8 bg-[#fffaf8] px-4 py-3">
                      <p class="font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/50 uppercase">
                        Univers
                      </p>
                      <p class="mt-1 font-serif text-lg leading-tight text-[#3d3834]">
                        {service.universe}
                      </p>
                    </div>
                    <div class="rounded-2xl border border-[#3d3834]/8 bg-[#fffaf8] px-4 py-3">
                      <p class="font-sans text-[9px] font-bold tracking-[0.2em] text-[#3d3834]/50 uppercase">
                        Focus
                      </p>
                      <p class="mt-1 font-serif text-lg leading-tight text-[#3d3834]">
                        {service.focus}
                      </p>
                    </div>
                  </div>
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── PROCESSUS & ENGAGEMENTS ─── -->
    <section class="relative overflow-hidden bg-[#FFFAFA] px-6 py-24">
      <div class="site-shell relative grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
        <div
          class="section-panel fade-up rounded-[2.35rem] border border-[#3d3834]/10 bg-[#3d3834] p-8 text-[#FFFAFA] shadow-[0_24px_80px_-48px_rgba(61,56,52,0.42)] md:p-10"
        >
          <p
            class="font-sans text-[10px] font-bold tracking-[0.35em] text-[#3a4d45] uppercase"
          >
            Comment ça se passe
          </p>
          <h2 class="mt-5 font-serif text-4xl leading-none md:text-5xl">
            Une base claire pour discuter du besoin, du rendu et du bon niveau
            de personnalisation.
          </h2>
          <p
            class="mt-6 max-w-xl font-sans text-base leading-relaxed text-[#FFFAFA]"
          >
            Certains tarifs sont fixes, d'autres passent par un devis. Dans tous
            les cas, l'idée est de cadrer la demande avec précision pour que le
            visuel final soit cohérent avec ton univers de livre.
          </p>

          <div class="mt-10 space-y-4 border-t border-[#FFFAFA]/10 pt-8">
            {
              process.map((item) => (
                <div class="flex items-start gap-4">
                  <span class="font-serif text-3xl text-[#3a4d45]">
                    {item.step}
                  </span>
                  <div>
                    <p class="font-sans text-[10px] font-bold tracking-[0.3em] text-[#FFFAFA] uppercase">
                      {item.title}
                    </p>
                    <p class="mt-2 font-sans text-sm leading-relaxed text-[#FFFAFA]">
                      {item.text}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {
            commitments.map((item) => (
              <article class="section-panel fade-up rounded-[2.1rem] border border-[#3d3834]/10 bg-[#FFFAFA] p-7 shadow-[0_20px_70px_-45px_rgba(61,56,52,0.34)] backdrop-blur-sm">
                <p class="font-sans text-[10px] font-bold tracking-[0.28em] text-[#3a4d45] uppercase">
                  Repère
                </p>
                <h3 class="mt-4 font-serif text-3xl leading-none text-[#3d3834]">
                  {item.title}
                </h3>
                <p class="mt-4 font-sans text-base leading-relaxed text-[#3d3834]/78">
                  {item.text}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── CTA FINAL ─── -->
    <section class="relative overflow-hidden bg-[#FFFAFA] px-6 py-24">
      <div class="site-shell relative mt-20">
        <div
          class="section-panel fade-up rounded-[2.5rem] border border-[#3d3834]/10 bg-[#3d3834] px-8 py-10 text-[#FFFAFA] shadow-[0_26px_90px_-55px_rgba(61,56,52,0.45)] md:px-10 md:py-12"
        >
          <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
            <div>
              <p
                class="font-sans text-[10px] font-bold tracking-[0.35em] text-[#3a4d45] uppercase"
              >
                Demande personnalisée
              </p>
              <h2 class="mt-4 font-serif text-4xl leading-none md:text-5xl">
                Pour toute demande personnalisée ou pour un devis, écris-moi
                directement.
              </h2>
              <p
                class="mt-4 max-w-2xl font-sans text-base leading-relaxed text-[#FFFAFA]"
              >
                Mail&nbsp;: {contact.email}<br />
                Instagram&nbsp;: {contact.instagramHandle}
              </p>
            </div>

            <div class="flex flex-wrap gap-3 lg:justify-end">
              <a
                href={`mailto:${contact.email}`}
                class="inline-flex items-center gap-3 rounded-full bg-[#3a4d45] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#FFFAFA] uppercase transition-all duration-300 hover:-translate-y-1 hover:bg-[#FFFAFA] hover:text-[#3d3834]"
              >
                Envoyer un mail
              </a>
              <a
                href={contact.instagramUrl}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-3 rounded-full border border-[#FFFAFA]/12 bg-[#FFFAFA] px-7 py-4 font-sans text-[11px] font-bold tracking-[0.25em] text-[#3d3834] uppercase transition-all duration-300 hover:-translate-y-1 hover:bg-[#FFFAFA]"
              >
                Ouvrir Instagram
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Scrollbar discrète pour les galeries */
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: rgba(61, 56, 52, 0.15) transparent;
  }
  .scrollbar-thin::-webkit-scrollbar {
    height: 6px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
